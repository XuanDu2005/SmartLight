// =============================================================================
//  IDENTITY & AUTH
// =============================================================================

model User {
  id                       String         @id @default(cuid())
  email                    String         @unique @db.Citext
  passwordHash             String         @map("password_hash")
  firstName                String?        @map("first_name") @db.VarChar(100)
  lastName                 String?        @map("last_name") @db.VarChar(100)
  phone                    String?        @db.VarChar(20)
  locale                   String         @default("vi-VN") @db.VarChar(10)
  status                   UserStatus     @default(PENDING_VERIFICATION)
  emailVerifiedAt          DateTime?      @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationToken   String?        @map("email_verification_token") @db.VarChar(128)
  passwordChangedAt        DateTime?      @map("password_changed_at") @db.Timestamptz(6)
  failedLoginCount         Int            @default(0) @map("failed_login_count")
  lockedUntil              DateTime?      @map("locked_until") @db.Timestamptz(6)
  acceptsMarketing         Boolean        @default(false) @map("accepts_marketing")
  gdprAnonymizedAt         DateTime?      @map("gdpr_anonymized_at") @db.Timestamptz(6)
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?      @map("deleted_at") @db.Timestamptz(6)

  addresses                Address[]
  refreshTokens            RefreshToken[]
  sessions                 UserSession[]
  mfaSecret                MfaSecret?
  carts                    Cart[]
  orders                   Order[]
  reviews                  Review[]
  returns                  Return[]
  supportTickets           SupportTicket[] @relation("CustomerTickets")
  notificationPreferences  NotificationPreference[]
  cookieConsents           CookieConsent[]
  stockMovements           StockMovement[] @relation("StockMovementCustomer")
  inventoryAdjustments     InventoryAdjustment[] @relation("InventoryAdjCustomer")
  notificationLogs         NotificationLog[]
  createdOrders            Order[] @relation("OrderCreatedBy")
  voucherUsages            VoucherUsage[]
  promotionUsages          PromotionUsage[]
  auditLogs                AuditLog[] @relation("AuditActorUser")

  @@index([phone])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt(sort: Desc)])
  @@map("user")
}

model AdminUser {
  id                 String              @id @default(cuid())
  email              String              @unique @db.Citext
  passwordHash       String              @map("password_hash")
  displayName        String              @map("display_name") @db.VarChar(120)
  status             AdminUserStatus     @default(PENDING_MFA_SETUP)
  lastLoginAt        DateTime?           @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp        String?             @map("last_login_ip") @db.VarChar(45)
  failedLoginCount   Int                 @default(0) @map("failed_login_count")
  lockedUntil        DateTime?           @map("locked_until") @db.Timestamptz(6)
  mustChangePassword Boolean             @default(false) @map("must_change_password")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz(6)

  roles              AdminUserRole[]
  refreshTokens      RefreshToken[]
  sessions           UserSession[]
  mfaSecret          MfaSecret?
  addresses          Address[]
  reviewReplies      ReviewReply[]
  ticketAssignments  SupportTicket[] @relation("AssignedAgent")
  ticketMessages     TicketMessage[] @relation("MessageAuthor")
  inventoryAdjustments InventoryAdjustment[] @relation("InventoryAdjAdmin")
  refundRequests     Refund[] @relation("RefundRequester")
  returnInspections  ReturnInspection[]
  reviewModerations  Review[] @relation("ReviewModerator")
  systemConfigUpdates SystemConfig[]
  staticPages        StaticPage[]
  featureFlagUpdates FeatureFlag[]
  notificationLogs   NotificationLog[]
  auditLogs          AuditLog[] @relation("AuditActorAdmin")

  @@index([status])
  @@index([deletedAt])
  @@map("admin_user")
}

model Role {
  id           String      @id @default(cuid())
  code         String      @unique @db.VarChar(60)   // e.g. "super_admin", "catalog_manager"
  displayName  String      @map("display_name") @db.VarChar(120)
  scope        RoleScope   @default(CUSTOM)
  description  String?     @db.Text
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  adminUsers   AdminUserRole[]
  permissions  RolePermission[]

  @@map("role")
}

model Permission {
  id          String              @id @default(cuid())
  code        String              @unique @db.VarChar(100)   // e.g. "catalog.product.update"
  category    String              @db.VarChar(60)
  displayName String              @map("display_name") @db.VarChar(160)
  description String?             @db.Text
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  roles       RolePermission[]

  @@index([category])
  @@map("permission")
}

model AdminUserRole {
  id           String     @id @default(cuid())
  adminUserId  String     @map("admin_user_id")
  roleId       String     @map("role_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy   String?    @map("assigned_by")
  revokedAt    DateTime?  @map("revoked_at") @db.Timestamptz(6)

  adminUser    AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([adminUserId, roleId])
  @@index([roleId])
  @@map("admin_user_role")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

model Address {
  id             String           @id @default(cuid())
  ownerType      AddressOwnerType @map("owner_type")
  userId         String?          @map("user_id")
  adminUserId    String?          @map("admin_user_id")
  fullName       String           @map("full_name") @db.VarChar(120)
  phone          String           @db.VarChar(20)
  provinceCode   String           @map("province_code") @db.VarChar(20)
  provinceName   String           @map("province_name") @db.VarChar(80)
  districtCode   String           @map("district_code") @db.VarChar(20)
  districtName   String           @map("district_name") @db.VarChar(80)
  wardCode       String?          @map("ward_code") @db.VarChar(20)
  wardName       String?          @map("ward_name") @db.VarChar(80)
  street         String           @db.VarChar(255)
  isDefault      Boolean          @default(false) @map("is_default")
  label          String?          @db.VarChar(60)              // "Home", "Office"
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)

  user           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser      AdminUser?       @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  orderAddresses OrderAddress[]

  @@index([userId])
  @@index([adminUserId])
  @@index([provinceCode, districtCode])
  @@index([deletedAt])
  @@map("address")
}

model MfaSecret {
  id             String     @id @default(cuid())
  userId         String?    @unique @map("user_id")
  adminUserId    String?    @unique @map("admin_user_id")
  type           MfaType    @default(TOTP)
  encryptedSecret String    @map("encrypted_secret") @db.Text
  issuer         String     @default("SmartLight") @db.VarChar(60)
  enabledAt      DateTime   @default(now()) @map("enabled_at") @db.Timestamptz(6)
  lastUsedAt     DateTime?  @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser      AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  recoveryCodes  RecoveryCode[]

  @@map("mfa_secret")
}

model RecoveryCode {
  id           String     @id @default(cuid())
  mfaSecretId  String     @map("mfa_secret_id")
  codeHash     String     @map("code_hash") @db.VarChar(255)
  usedAt       DateTime?  @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  mfaSecret    MfaSecret  @relation(fields: [mfaSecretId], references: [id], onDelete: Cascade)

  @@unique([mfaSecretId, codeHash])
  @@index([mfaSecretId])
  @@map("recovery_code")
}

model RefreshToken {
  id              String              @id @default(cuid())
  tokenHash       String              @unique @map("token_hash") @db.VarChar(255)
  userId          String?             @map("user_id")
  adminUserId     String?             @map("admin_user_id")
  sessionId       String?             @map("session_id")
  reason          RefreshTokenReason  @default(REFRESH)
  issuedAt        DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt       DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime?           @map("revoked_at") @db.Timestamptz(6)
  revokedReason   String?             @map("revoked_reason") @db.VarChar(120)
  replacedById    String?             @unique @map("replaced_by_id")
  userAgent       String?             @map("user_agent") @db.VarChar(255)
  ip              String?             @db.VarChar(45)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user            User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser       AdminUser?          @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  session         UserSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token")
}

model UserSession {
  id              String              @id @default(cuid())
  userId          String?             @map("user_id")
  adminUserId     String?             @map("admin_user_id")
  status          UserSessionStatus   @default(ACTIVE)
  ip              String              @db.VarChar(45)
  userAgent       String              @map("user_agent") @db.VarChar(255)
  deviceLabel     String?             @map("device_label") @db.VarChar(80)
  geoCountry      String?             @map("geo_country") @db.VarChar(2)
  geoCity         String?             @map("geo_city") @db.VarChar(80)
  issuedAt        DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  lastSeenAt      DateTime            @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt       DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime?           @map("revoked_at") @db.Timestamptz(6)

  user            User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser       AdminUser?          @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]

  @@index([userId])
  @@index([adminUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("user_session")
}

// =============================================================================
//  CATALOG
// =============================================================================

model Category {
  id           String         @id @default(cuid())
  parentId     String?        @map("parent_id")
  slug         String         @unique @db.VarChar(120)
  name         String         @db.VarChar(160)
  description  String?        @db.Text
  imageMediaId String?        @map("image_media_id")
  displayOrder Int            @default(0) @map("display_order")
  level        Int            @default(0)
  path         String         @default("/") @db.VarChar(500)  // materialized path "/1/22/47/"
  status       CategoryStatus @default(DRAFT)
  isFeatured   Boolean        @default(false) @map("is_featured")
  taxExempt    Boolean        @default(false) @map("tax_exempt")
  metaTitle    String?        @map("meta_title") @db.VarChar(255)
  metaDesc     String?        @map("meta_description") @db.VarChar(500)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  parent       Category?      @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children     Category[]     @relation("CategoryTree")
  products     Product[]
  imageMedia   MediaFile?     @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([slug])
  @@index([status, displayOrder])
  @@index([deletedAt])
  @@map("category")
}

model Brand {
  id           String      @id @default(cuid())
  slug         String      @unique @db.VarChar(120)
  name         String      @db.VarChar(160)
  description  String?     @db.Text
  logoMediaId  String?     @map("logo_media_id")
  isFeatured   Boolean     @default(false) @map("is_featured")
  status       BrandStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  products     Product[]
  logoMedia    MediaFile?  @relation(fields: [logoMediaId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([slug])
  @@map("brand")
}

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique @db.VarChar(160)
  name          String         @db.VarChar(255)
  shortDesc     String?        @map("short_description") @db.VarChar(500)
  description   String?        @db.Text
  categoryId    String         @map("category_id")
  brandId       String?        @map("brand_id")
  basePrice     Decimal        @map("base_price") @db.Decimal(20, 4)
  compareAtPrice Decimal?      @map("compare_at_price") @db.Decimal(20, 4)
  taxRateId     String?        @map("tax_rate_id")
  status        ProductStatus  @default(DRAFT)
  isFeatured    Boolean        @default(false) @map("is_featured")
  isNewArrival  Boolean        @default(false) @map("is_new_arrival")
  publishedAt   DateTime?      @map("published_at") @db.Timestamptz(6)
  viewCount     BigInt         @default(0) @map("view_count")
  ratingAvg     Decimal        @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount   Int            @default(0) @map("rating_count")
  tags          String[]       @default([])              // text[] in PG
  metaTitle     String?        @map("meta_title") @db.VarChar(255)
  metaDesc      String?        @map("meta_description") @db.VarChar(500)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(6)

  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand         Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  taxRate       TaxRate?       @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  images        ProductImage[]
  attributes    ProductAttributeValue[]
  reviews       Review[]

  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([brandId, status])
  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, status])
  @@index([priceRange: basePrice], type: BTree)
  @@index([tags], type: Gin)
  @@index([deletedAt])
  @@map("product")
}

model ProductVariant {
  id                 String              @id @default(cuid())
  productId          String              @map("product_id")
  sku                String              @unique @db.VarChar(64)
  barcode            String?             @db.VarChar(64)
  name               String              @db.VarChar(255)
  price              Decimal             @db.Decimal(20, 4)
  compareAtPrice     Decimal?            @map("compare_at_price") @db.Decimal(20, 4)
  cost               Decimal?            @db.Decimal(20, 4)
  weightGrams        Int?                @map("weight_grams")
  lengthMm           Int?                @map("length_mm")
  widthMm            Int?                @map("width_mm")
  heightMm           Int?                @map("height_mm")
  status             ProductVariantStatus @default(ACTIVE)
  isDefault          Boolean             @default(false) @map("is_default")
  displayOrder       Int                 @default(0) @map("display_order")
  attributesJson     Json                @default("{}") @map("attributes_json") @db.JsonB
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz(6)

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory          Inventory?
  inventoryMovements StockMovement[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  returnItems        ReturnItem[]
  images             ProductImage[]

  @@index([productId, status, displayOrder])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
  @@map("product_variant")
}

model ProductImage {
  id             String          @id @default(cuid())
  productId      String          @map("product_id")
  variantId      String?         @map("variant_id")
  mediaId        String          @map("media_id")
  altText        String?         @map("alt_text") @db.VarChar(255)
  displayOrder   Int             @default(0) @map("display_order")
  isPrimary      Boolean         @default(false) @map("is_primary")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  media          MediaFile       @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([productId, displayOrder])
  @@index([variantId])
  @@index([mediaId])
  @@map("product_image")
}

model ProductAttribute {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(60)   // "color", "wattage"
  displayName String           @map("display_name") @db.VarChar(120)
  dataType    AttributeDataType @default(TEXT) @map("data_type")
  unit        String?          @db.VarChar(20)
  isFilterable Boolean         @default(true) @map("is_filterable")
  isRequired  Boolean          @default(false) @map("is_required")
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz(6)

  values      ProductAttributeValue[]

  @@map("product_attribute")
}

model ProductAttributeValue {
  id              String          @id @default(cuid())
  productId       String          @map("product_id")
  attributeId     String          @map("attribute_id")
  valueText       String?         @map("value_text") @db.VarChar(255)
  valueNumber     Decimal?        @map("value_number") @db.Decimal(20, 4)
  valueBoolean    Boolean?        @map("value_boolean")
  valueColorHex   String?         @map("value_color_hex") @db.VarChar(7)
  valueListValue  String?         @map("value_list_value") @db.VarChar(120)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute       ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_value")
}

// =============================================================================
//  INVENTORY
// =============================================================================

model Inventory {
  id               String          @id @default(cuid())
  productVariantId String          @unique @map("product_variant_id")
  warehouseCode    String          @default("MAIN") @map("warehouse_code") @db.VarChar(40)
  onHand           Int             @default(0) @map("on_hand")
  reserved         Int             @default(0)
  available        Int             @default(0)           // computed: on_hand - reserved; updated via CHECK trigger
  lowStockThreshold Int            @default(5) @map("low_stock_threshold")
  allowBackorder   Boolean         @default(false) @map("allow_backorder")
  lastCountedAt    DateTime?       @map("last_counted_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  variant          ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, warehouseCode])
  @@index([available])
  @@index([lowStockThreshold])
  @@map("inventory")
}

model StockMovement {
  id               String              @id @default(cuid())
  productVariantId String              @map("product_variant_id")
  type             StockMovementType
  quantity         Int                                       // signed: +in / -out
  onHandAfter      Int                 @map("on_hand_after")
  reservedAfter    Int                 @map("reserved_after")
  reason           String?             @db.VarChar(255)
  referenceType    String?             @map("reference_type") @db.VarChar(60)   // "order", "return", "adjustment"
  referenceId      String?             @map("reference_id")
  customerId       String?             @map("customer_id")
  createdByType    ActorType           @default(SYSTEM) @map("created_by_type")
  createdById      String?             @map("created_by_id")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  variant          ProductVariant      @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  customer         User?               @relation("StockMovementCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([productVariantId, createdAt(sort: Desc)])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt(sort: Desc)])
  @@map("stock_movement")
}

model StockReservation {
  id                String                  @id @default(cuid())
  productVariantId  String                  @map("product_variant_id")
  quantity          Int
  status            StockReservationStatus  @default(ACTIVE)
  cartId            String?                 @map("cart_id")
  orderId           String?                 @map("order_id")
  expiresAt         DateTime                @map("expires_at") @db.Timestamptz(6)
  consumedAt        DateTime?               @map("consumed_at") @db.Timestamptz(6)
  releasedAt        DateTime?               @map("released_at") @db.Timestamptz(6)
  releasedReason    String?                 @map("released_reason") @db.VarChar(80)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart              Cart?                   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  order             Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productVariantId, status])
  @@index([status, expiresAt])
  @@index([cartId])
  @@index([orderId])
  @@map("stock_reservation")
}

model InventoryAdjustment {
  id                String                     @id @default(cuid())
  productVariantId  String                     @map("product_variant_id")
  quantityDelta     Int                        @map("quantity_delta")
  onHandAfter       Int                        @map("on_hand_after")
  reason            InventoryAdjustmentReason
  note              String?                    @db.Text
  customerId        String?                    @map("customer_id")
  adminUserId       String?                    @map("admin_user_id")
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)

  customer          User?                      @relation("InventoryAdjCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  adminUser         AdminUser?                 @relation("InventoryAdjAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([productVariantId, createdAt(sort: Desc)])
  @@map("inventory_adjustment")
}

// =============================================================================
//  MEDIA
// =============================================================================

model MediaFile {
  id              String        @id @default(cuid())
  provider        String        @default("cloudinary") @db.VarChar(40)
  providerAssetId String        @map("provider_asset_id") @db.VarChar(255)
  url             String        @db.Text
  secureUrl       String        @map("secure_url") @db.Text
  mimeType        String        @map("mime_type") @db.VarChar(60)
  sizeBytes       BigInt        @map("size_bytes")
  width           Int?
  height          Int?
  durationSeconds Int?          @map("duration_seconds")
  purpose         MediaPurpose
  variantsJson    Json          @default("{}") @map("variants_json") @db.JsonB  // {thumbnail, medium, large}
  checksum        String?       @db.VarChar(128)
  ownerType       String?       @map("owner_type") @db.VarChar(40)
  ownerId         String?       @map("owner_id")
  createdById     String?       @map("created_by_id")
  uploadedAt      DateTime      @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  productImages   ProductImage[]
  categoryBanners Category[]    @relation("CategoryImage")
  brandLogos      Brand[]       @relation("BrandLogo")

  @@index([provider, providerAssetId])
  @@index([ownerType, ownerId])
  @@index([purpose, deletedAt])
  @@map("media_file")
}

// =============================================================================
//  CART & CHECKOUT
// =============================================================================

model Cart {
  id               String        @id @default(cuid())
  userId           String?       @map("user_id")
  guestSessionId   String?       @map("guest_session_id") @db.VarChar(128)
  status           CartStatus    @default(ACTIVE)
  couponId         String?       @map("coupon_id")
  currency         String        @default("VND") @db.VarChar(3)
  subtotal         Decimal       @default(0) @db.Decimal(20, 4)
  discountTotal    Decimal       @default(0) @map("discount_total") @db.Decimal(20, 4)
  taxTotal         Decimal       @default(0) @map("tax_total") @db.Decimal(20, 4)
  shippingTotal    Decimal       @default(0) @map("shipping_total") @db.Decimal(20, 4)
  grandTotal       Decimal       @default(0) @map("grand_total") @db.Decimal(20, 4)
  itemCount        Int           @default(0) @map("item_count")
  expiresAt        DateTime      @map("expires_at") @db.Timestamptz(6)
  lastActivityAt   DateTime      @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  convertedOrderId String?       @unique @map("converted_order_id")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon           Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  convertedOrder   Order?        @relation("CartConvertedToOrder", fields: [convertedOrderId], references: [id], onDelete: SetNull)
  items            CartItem[]
  reservations     StockReservation[]
  checkoutSessions CheckoutSession[]

  @@index([userId, status])
  @@index([guestSessionId, status])
  @@index([status, expiresAt])
  @@index([lastActivityAt])
  @@map("cart")
}

model CartItem {
  id                String        @id @default(cuid())
  cartId            String        @map("cart_id")
  productVariantId  String        @map("product_variant_id")
  quantity          Int
  unitPrice         Decimal       @map("unit_price") @db.Decimal(20, 4)
  lineSubtotal      Decimal       @map("line_subtotal") @db.Decimal(20, 4)
  taxAmount         Decimal       @map("tax_amount") @db.Decimal(20, 4)
  lineTotal         Decimal       @map("line_total") @db.Decimal(20, 4)
  productNameSnapshot String      @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot String     @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot       String        @map("sku_snapshot") @db.VarChar(64)
  reservationId     String?       @unique @map("reservation_id")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz(6)

  cart              Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant           ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  reservation       StockReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@unique([cartId, productVariantId])
  @@index([productVariantId])
  @@map("cart_item")
}

model CheckoutSession {
  id                   String                   @id @default(cuid())
  cartId               String                   @map("cart_id")
  userId               String?                  @map("user_id")
  guestEmail           String?                  @map("guest_email") @db.VarChar(255)
  guestPhone           String?                  @map("guest_phone") @db.VarChar(20)
  status               CheckoutSessionStatus    @default(IN_PROGRESS)
  step                 String                   @default("address") @db.VarChar(40)
  shippingAddressId    String?                  @map("shipping_address_id")
  billingAddressId     String?                  @map("billing_address_id")
  shippingMethodId     String?                  @map("shipping_method_id")
  paymentProvider      PaymentProvider?         @map("payment_provider")
  paymentIntentId      String?                  @map("payment_intent_id")
  totalAmount          Decimal                  @map("total_amount") @db.Decimal(20, 4)
  currency             String                   @default("VND") @db.VarChar(3)
  locale               String                   @default("vi-VN") @db.VarChar(10)
  idempotencyKey       String?                  @unique @map("idempotency_key") @db.VarChar(120)
  metadataJson         Json                     @default("{}") @map("metadata_json") @db.JsonB
  expiresAt            DateTime                 @map("expires_at") @db.Timestamptz(6)
  completedAt          DateTime?                @map("completed_at") @db.Timestamptz(6)
  cancelledAt          DateTime?                @map("cancelled_at") @db.Timestamptz(6)
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart                 Cart                     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([status, expiresAt])
  @@index([userId])
  @@map("checkout_session")
}

// =============================================================================
//  PROMOTION, TAX
// =============================================================================

model Coupon {
  id                  String           @id @default(cuid())
  code                String           @unique @db.Citext  // CITEXT: case-insensitive code
  promotionId         String           @map("promotion_id")
  description         String?          @db.Text
  status              VoucherStatus    @default(ACTIVE)
  usageLimit          Int?             @map("usage_limit")
  usageLimitPerUser   Int?             @map("usage_limit_per_user")
  usageCount          Int              @default(0) @map("usage_count")
  minimumOrderTotal   Decimal?         @map("minimum_order_total") @db.Decimal(20, 4)
  startsAt            DateTime?        @map("starts_at") @db.Timestamptz(6)
  endsAt              DateTime?        @map("ends_at") @db.Timestamptz(6)
  firstOrderOnly      Boolean          @default(false) @map("first_order_only")
  isPublic            Boolean          @default(true) @map("is_public")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz(6)

  promotion           Promotion        @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  usages              VoucherUsage[]
  carts               Cart[]

  @@index([status, endsAt])
  @@index([startsAt, endsAt])
  @@map("coupon")
}

model Promotion {
  id                  String                 @id @default(cuid())
  name                String                 @db.VarChar(255)
  description         String?                @db.Text
  type                PromotionType
  status              PromotionStatus        @default(DRAFT)
  discountTarget     PromotionDiscountTarget @default(ORDER_TOTAL) @map("discount_target")
  discountValue      Decimal                @map("discount_value") @db.Decimal(20, 4)   // e.g. 10.0000 (%) or 50,000 VND
  maxDiscountAmount  Decimal?               @map("max_discount_amount") @db.Decimal(20, 4)
  priority           Int                    @default(0)                              // ordering when stacking
  startsAt           DateTime?              @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime?              @map("ends_at") @db.Timestamptz(6)
  usageLimit         Int?                   @map("usage_limit")
  usageCount         Int                    @default(0) @map("usage_count")
  combinable         Boolean                @default(false)                          // can stack with others
  conditionsJson     Json                   @default("{}") @map("conditions_json") @db.JsonB   // categories, products, min cart
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?              @map("deleted_at") @db.Timestamptz(6)

  coupons            Coupon[]
  usages             PromotionUsage[]

  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([type])
  @@map("promotion")
}

model VoucherUsage {
  id              String     @id @default(cuid())
  couponId        String     @map("coupon_id")
  userId          String     @map("user_id")
  orderId         String     @map("order_id")
  discountAmount  Decimal    @map("discount_amount") @db.Decimal(20, 4)
  usedAt          DateTime   @default(now()) @map("used_at") @db.Timestamptz(6)

  coupon          Coupon     @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order      @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([couponId, userId, orderId])
  @@index([userId])
  @@index([orderId])
  @@map("voucher_usage")
}

model PromotionUsage {
  id               String     @id @default(cuid())
  promotionId      String     @map("promotion_id")
  userId           String     @map("user_id")
  orderId          String     @map("order_id")
  discountAmount   Decimal    @map("discount_amount") @db.Decimal(20, 4)
  usedAt           DateTime   @default(now()) @map("used_at") @db.Timestamptz(6)

  promotion        Promotion  @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order            Order      @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([promotionId, userId, orderId])
  @@index([userId])
  @@index([orderId])
  @@map("promotion_usage")
}

model TaxRate {
  id           String     @id @default(cuid())
  code         String     @unique @db.VarChar(40)   // "VAT-VN-10", "VAT-VN-8"
  name         String     @db.VarChar(120)
  ratePercent  Decimal    @map("rate_percent") @db.Decimal(5, 2)   // 10.00 means 10%
  description  String?    @db.Text
  isDefault    Boolean    @default(false) @map("is_default")
  isActive     Boolean    @default(true) @map("is_active")
  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo  DateTime?  @map("effective_to") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  products     Product[]

  @@index([isActive, effectiveFrom])
  @@map("tax_rate")
}

model TaxExemption {
  id           String     @id @default(cuid())
  categoryId   String     @map("category_id")
  reason       String     @db.VarChar(255)
  approvedBy   String     @map("approved_by")
  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo  DateTime?  @map("effective_to") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  @@unique([categoryId, effectiveFrom])
  @@index([categoryId])
  @@map("tax_exemption")
}

// =============================================================================
//  ORDERS
// =============================================================================

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique @default(cuid()) @map("order_number") @db.VarChar(40)
  userId            String?           @map("user_id")
  guestEmail        String?           @map("guest_email") @db.VarChar(255)
  guestPhone        String?           @map("guest_phone") @db.VarChar(20)
  status            OrderStatus       @default(PENDING)
  currency          String            @default("VND") @db.VarChar(3)
  subtotal          Decimal           @db.Decimal(20, 4)
  discountTotal     Decimal           @default(0) @map("discount_total") @db.Decimal(20, 4)
  taxTotal          Decimal           @default(0) @map("tax_total") @db.Decimal(20, 4)
  shippingTotal     Decimal           @default(0) @map("shipping_total") @db.Decimal(20, 4)
  grandTotal        Decimal           @map("grand_total") @db.Decimal(20, 4)
  paidAt            DateTime?         @map("paid_at") @db.Timestamptz(6)
  cancelledAt       DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancelReason      String?           @map("cancel_reason") @db.VarChar(255)
  locale            String            @default("vi-VN") @db.VarChar(10)
  customerNotes     String?           @map("customer_notes") @db.Text
  internalNotes     String?           @map("internal_notes") @db.Text
  createdById       String?           @map("created_by_id")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz(6)
  // Immutability: only createdAt/paidAt/updatedAt allowed to change after CONFIRMED; enforced via DB rule (V1.1 PG trigger)

  items             OrderItem[]
  addresses         OrderAddress[]
  statusHistory     OrderStatusHistory[]
  shipment          Shipment?
  payment           Payment?
  refunds           Refund[]
  returns           Return[]
  voucherUsages     VoucherUsage[]
  promotionUsages   PromotionUsage[]
  stockReservations StockReservation[]
  convertedFromCart Cart?              @relation("CartConvertedToOrder")
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdBy         User?             @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([guestEmail])
  @@index([paidAt])
  @@index([deletedAt])
  @@map("order")
}

model OrderItem {
  id                  String          @id @default(cuid())
  orderId             String          @map("order_id")
  productVariantId    String          @map("product_variant_id")
  quantity            Int
  unitPrice           Decimal         @map("unit_price") @db.Decimal(20, 4)
  unitCostSnapshot    Decimal?        @map("unit_cost_snapshot") @db.Decimal(20, 4)
  taxRatePercent      Decimal         @map("tax_rate_percent") @db.Decimal(5, 2)
  taxAmount           Decimal         @map("tax_amount") @db.Decimal(20, 4)
  discountShare       Decimal         @default(0) @map("discount_share") @db.Decimal(20, 4)
  lineSubtotal        Decimal         @map("line_subtotal") @db.Decimal(20, 4)
  lineTotal           Decimal         @map("line_total") @db.Decimal(20, 4)
  // Snapshots (immutable)
  productNameSnapshot String          @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot String          @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot         String          @map("sku_snapshot") @db.VarChar(64)
  productSlugSnapshot String          @map("product_slug_snapshot") @db.VarChar(160)
  imageSnapshotUrl    String?         @map("image_snapshot_url") @db.Text
  weightGramsSnapshot Int?            @map("weight_grams_snapshot")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant             ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  returnItems         ReturnItem[]

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_item")
}

model OrderAddress {
  id            String   @id @default(cuid())
  orderId       String   @map("order_id")
  addressId     String?  @map("address_id")
  kind          String   @db.VarChar(20)   // "shipping" | "billing"
  fullName      String   @map("full_name") @db.VarChar(120)
  phone         String   @db.VarChar(20)
  provinceCode  String   @map("province_code") @db.VarChar(20)
  provinceName  String   @map("province_name") @db.VarChar(80)
  districtCode  String   @map("district_code") @db.VarChar(20)
  districtName  String   @map("district_name") @db.VarChar(80)
  wardCode      String?  @map("ward_code") @db.VarChar(20)
  wardName      String?  @map("ward_name") @db.VarChar(80)
  street        String   @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address       Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_address")
}

model OrderStatusHistory {
  id             String      @id @default(cuid())
  orderId        String      @map("order_id")
  fromStatus     OrderStatus? @map("from_status")
  toStatus       OrderStatus @map("to_status")
  changedByType  ActorType   @default(SYSTEM) @map("changed_by_type")
  changedById    String?     @map("changed_by_id")
  reason         String?     @db.VarChar(255)
  metadataJson   Json        @default("{}") @map("metadata_json") @db.JsonB
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_status_history")
}

// =============================================================================
//  PAYMENTS
// =============================================================================

model Payment {
  id                 String           @id @default(cuid())
  orderId            String           @unique @map("order_id")
  provider           PaymentProvider
  status             PaymentStatus    @default(PENDING)
  amount             Decimal          @db.Decimal(20, 4)
  currency           String           @default("VND") @db.VarChar(3)
  providerTxnId      String?          @map("provider_txn_id") @db.VarChar(255)
  providerReference  String?          @map("provider_reference") @db.VarChar(255)
  idempotencyKey     String?          @unique @map("idempotency_key") @db.VarChar(120)
  authorizedAt       DateTime?        @map("authorized_at") @db.Timestamptz(6)
  capturedAt         DateTime?        @map("captured_at") @db.Timestamptz(6)
  failedAt           DateTime?        @map("failed_at") @db.Timestamptz(6)
  failureReason      String?          @map("failure_reason") @db.VarChar(255)
  expiresAt          DateTime?        @map("expires_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  order              Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions       PaymentTransaction[]
  refunds            Refund[]

  @@index([provider, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([providerTxnId])
  @@map("payment")
}

model PaymentTransaction {
  id              String                    @id @default(cuid())
  paymentId       String                    @map("payment_id")
  type            PaymentTransactionType
  status          PaymentTransactionStatus  @default(PENDING)
  amount          Decimal                   @db.Decimal(20, 4)
  providerCode    String?                   @map("provider_code") @db.VarChar(80)
  providerMessage String?                   @map("provider_message") @db.Text
  rawResponseJson Json?                     @map("raw_response_json") @db.JsonB
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  payment         Payment                   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt(sort: Desc)])
  @@index([type])
  @@map("payment_transaction")
}

model WebhookEvent {
  id                String              @id @default(cuid())
  provider          WebhookProvider
  eventId           String              @map("event_id") @db.VarChar(255)
  eventType         String              @map("event_type") @db.VarChar(80)
  status            WebhookEventStatus  @default(RECEIVED)
  payloadJson       Json                @map("payload_json") @db.JsonB
  signature         String?             @db.VarChar(512)
  receivedAt        DateTime            @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt       DateTime?           @map("processed_at") @db.Timestamptz(6)
  errorMessage      String?             @map("error_message") @db.Text
  retryCount        Int                 @default(0) @map("retry_count")
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([status, receivedAt])
  @@index([archivedAt])
  @@map("webhook_event")
}

model Refund {
  id                String       @id @default(cuid())
  paymentId         String       @map("payment_id")
  orderId           String       @map("order_id")
  amount            Decimal      @db.Decimal(20, 4)
  reason            String       @db.VarChar(255)
  status            RefundStatus @default(PENDING)
  providerRefundId  String?      @map("provider_refund_id") @db.VarChar(255)
  requestedByType   ActorType    @default(ADMIN_USER) @map("requested_by_type")
  requestedById     String?      @map("requested_by_id")
  processedAt       DateTime?    @map("processed_at") @db.Timestamptz(6)
  failureReason     String?      @map("failure_reason") @db.VarChar(255)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  requestedBy       AdminUser?   @relation("RefundRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([orderId])
  @@index([status])
  @@map("refund")
}

// =============================================================================
//  SHIPPING
// =============================================================================

model Shipment {
  id                String           @id @default(cuid())
  orderId           String           @unique @map("order_id")
  carrier           ShippingCarrier
  serviceCode       String           @map("service_code") @db.VarChar(60)
  trackingNumber    String?          @unique @map("tracking_number") @db.VarChar(120)
  status            ShipmentStatus   @default(CREATED)
  shippingFee       Decimal          @map("shipping_fee") @db.Decimal(20, 4)
  weightGrams       Int              @map("weight_grams")
  lengthMm          Int?             @map("length_mm")
  widthMm           Int?             @map("width_mm")
  heightMm          Int?             @map("height_mm")
  courierNotes      String?          @map("courier_notes") @db.Text
  labelUrl          String?          @map("label_url") @db.Text
  pickedUpAt        DateTime?        @map("picked_up_at") @db.Timestamptz(6)
  deliveredAt       DateTime?        @map("delivered_at") @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
