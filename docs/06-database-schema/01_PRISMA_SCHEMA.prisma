// =============================================================================
//  SmartLight — Single Vendor E-Commerce Platform
//  Prisma Schema — PostgreSQL 16
//
//  Source-of-truth models for the Database Schema Design phase.
//  Derived from:
//    docs/03-database-design/ (64 MVP entities)
//    docs/05-software-architecture/ (Module Architecture)
//    docs/04-api-design/ (REST contracts)
//
//  Conventions:
//    • String @id (cuid in V1, UUIDv7 in V2) for microservice portability
//    • Soft delete via deletedAt on all business entities
//    • createdAt / updatedAt on every model
//    • Money stored as Decimal @db.Decimal(20, 4) (VND, no minor unit at DB layer; renderer rounds)
//    • snake_case tables and columns via @map / @@map
//    • Cascade rules explicit
//    • Status fields enumerated
//    • Enum values UPPERCASE
//
//  IMPORTANT:
//    This is a DECLARATIVE schema file only. It contains no application code.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto, pg_trgm]
}

// =============================================================================
//  ENUMS
// =============================================================================

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED
  ANONYMIZED
}

enum AdminUserStatus {
  PENDING_MFA_SETUP
  ACTIVE
  SUSPENDED
  LOCKED
  DISABLED
}

enum RoleScope {
  SYSTEM    // immutable seeded roles
  CUSTOM    // admin-defined roles
}

enum AddressOwnerType {
  USER
  ADMIN_USER
}

enum MfaType {
  TOTP
  BACKUP_CODES
}

enum RefreshTokenReason {
