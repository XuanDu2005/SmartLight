  updatedById   String?    @map("updated_by_id")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedBy     AdminUser? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([category])
  @@map("system_config")
}

// =============================================================================
//  SHIPPING CONFIG (referenced where applicable)
// =============================================================================

model ShippingZone {
  id           String   @id @default(cuid())
  code         String   @unique @db.VarChar(40)
  name         String   @db.VarChar(120)
  provinceCodes String[] @default([]) @map("province_codes")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rates        ShippingRate[]

  @@map("shipping_zone")
}

model ShippingRate {
  id            String   @id @default(cuid())
  zoneId        String   @map("zone_id")
  carrier       ShippingCarrier
  serviceCode   String   @map("service_code") @db.VarChar(60)
  serviceName   String   @map("service_name") @db.VarChar(160)
  baseFee       Decimal  @map("base_fee") @db.Decimal(20, 4)
  perKgFee      Decimal  @default(0) @map("per_kg_fee") @db.Decimal(20, 4)
  minWeight     Int      @default(0) @map("min_weight")
  maxWeight     Int?     @map("max_weight")
  minOrderTotal Decimal? @map("min_order_total") @db.Decimal(20, 4)
  freeAbove     Decimal? @map("free_above") @db.Decimal(20, 4)
  estimatedDaysMin Int   @default(1) @map("estimated_days_min")
  estimatedDaysMax Int   @default(3) @map("estimated_days_max")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Restrict)

  @@unique([zoneId, carrier, serviceCode])
  @@index([carrier, isActive])
  @@map("shipping_rate")
}

// =============================================================================
//  IDEMPOTENCY (general-purpose)
// =============================================================================

model IdempotencyRecord {
  id            String   @id @default(cuid())
  key           String   @unique @db.VarChar(120)
  method        String   @db.VarChar(10)
  path          String   @db.VarChar(255)
  actorType     String   @map("actor_type") @db.VarChar(20)
  actorId       String?  @map("actor_id")
  requestHash   String   @map("request_hash") @db.VarChar(128)
  responseJson  Json?    @map("response_json") @db.JsonB
  responseStatus Int?    @map("response_status")
  inFlight      Boolean  @default(true) @map("in_flight")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("idempotency_record")
}

// =============================================================================
//  OUTBOX (event delivery guarantee)
// =============================================================================

model OutboxMessage {
  id            String   @id @default(cuid())
  eventId       String   @unique @map("event_id") @db.VarChar(64)
  aggregateType String   @map("aggregate_type") @db.VarChar(60)
  aggregateId   String   @map("aggregate_id") @db.VarChar(64)
  eventType     String   @map("event_type") @db.VarChar(120)
  payload       Json     @db.JsonB
  status        String   @default("PENDING") @db.VarChar(20)   // "PENDING" | "DISPATCHED" | "FAILED"
  retryCount    Int      @default(0) @map("retry_count")
  lastError     String?  @map("last_error") @db.Text
  availableAt   DateTime @default(now()) @map("available_at") @db.Timestamptz(6)
  dispatchedAt  DateTime? @map("dispatched_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_message")
}
