model EmailTemplate {
  id            String         @id @default(cuid())
  code          String         @db.VarChar(80)
  locale        TemplateLocale @default(VI)
  version       Int            @default(1)
  subject       String         @db.VarChar(255)
  bodyHtml      String         @map("body_html") @db.Text
  bodyText      String         @map("body_text") @db.Text
  variablesJson Json           @default("{}") @map("variables_json") @db.JsonB
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([code, locale, version])
  @@index([code, locale, isActive])
  @@map("email_template")
}

model NotificationLog {
  id              String              @id @default(cuid())
  channel         NotificationChannel
  templateCode    String              @map("template_code") @db.VarChar(80)
  recipientType   String              @map("recipient_type") @db.VarChar(20)   // "USER" | "ADMIN" | "EMAIL"
  recipientUserId String?             @map("recipient_user_id")
  recipientAdminId String?            @map("recipient_admin_id")
  recipientEmail  String?             @map("recipient_email") @db.VarChar(255)
  subject         String?             @db.VarChar(255)
  status          NotificationStatus  @default(QUEUED)
  providerMessageId String?           @map("provider_message_id") @db.VarChar(255)
  sentAt          DateTime?           @map("sent_at") @db.Timestamptz(6)
  deliveredAt     DateTime?           @map("delivered_at") @db.Timestamptz(6)
  failedAt        DateTime?           @map("failed_at") @db.Timestamptz(6)
  failureReason   String?             @map("failure_reason") @db.VarChar(255)
  metadataJson    Json                @default("{}") @map("metadata_json") @db.JsonB
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  recipientUser   User?               @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientAdmin  AdminUser?          @relation(fields: [recipientAdminId], references: [id], onDelete: SetNull)

  @@index([recipientEmail])
  @@index([recipientUserId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("notification_log")
}

model NotificationPreference {
  id                 String     @id @default(cuid())
  userId             String     @map("user_id")
  emailOrderUpdates  Boolean    @default(true) @map("email_order_updates")
  emailMarketing     Boolean    @default(false) @map("email_marketing")
  pushOrderUpdates   Boolean    @default(true) @map("push_order_updates")
  pushMarketing      Boolean    @default(false) @map("push_marketing")
  smsOrderUpdates    Boolean    @default(false) @map("sms_order_updates")
  smsSecurity        Boolean    @default(true) @map("sms_security")
  locale             String     @default("vi-VN") @db.VarChar(10)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

