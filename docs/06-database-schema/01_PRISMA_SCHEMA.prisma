}

model TrackingEvent {
  id            String   @id @default(cuid())
  shipmentId    String   @map("shipment_id")
  status        ShipmentStatus
  description   String   @db.VarChar(255)
  location      String?  @db.VarChar(120)
  carrierCode   String?  @map("carrier_code") @db.VarChar(80)
  occurredAt    DateTime @map("occurred_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, occurredAt(sort: Desc)])
  @@map("tracking_event")
}

// =============================================================================
//  RETURNS
// =============================================================================

model Return {
  id             String              @id @default(cuid())
  rmaNumber      String              @unique @default(cuid()) @map("rma_number") @db.VarChar(40)
  orderId        String              @map("order_id")
  userId         String              @map("user_id")
  status         OrderReturnStatus   @default(PENDING)
  reason         String              @db.VarChar(255)
  description    String?             @db.Text
  refundAmount   Decimal?            @map("refund_amount") @db.Decimal(20, 4)
  shippingRefund Decimal?            @map("shipping_refund") @db.Decimal(20, 4)
  approvedAt     DateTime?           @map("approved_at") @db.Timestamptz(6)
  receivedAt     DateTime?           @map("received_at") @db.Timestamptz(6)
  closedAt       DateTime?           @map("closed_at") @db.Timestamptz(6)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz(6)

  order          Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user           User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  items          ReturnItem[]
  inspections    ReturnInspection[]

  @@index([orderId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("rma_return")
}

model ReturnItem {
  id              String          @id @default(cuid())
  returnId        String          @map("return_id")
  orderItemId     String          @map("order_item_id")
  productVariantId String         @map("product_variant_id")
  quantity        Int
  reason          String          @db.VarChar(255)
  disposition     String?         @db.VarChar(40)   // "RESTOCK" | "DISPOSE" | "REPAIR"
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  return          Return          @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem       OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  variant         ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  inspection      ReturnInspection?

  @@index([returnId])
  @@index([orderItemId])
  @@map("return_item")
}

model ReturnInspection {
  id              String      @id @default(cuid())
  returnItemId    String      @unique @map("return_item_id")
  inspectorId     String      @map("inspector_id")
  outcome         String      @db.VarChar(20)   // "PASS" | "FAIL"
  condition       String?     @db.VarChar(120)
  notes           String?     @db.Text
  restockQuantity Int?        @map("restock_quantity")
  inspectedAt     DateTime    @default(now()) @map("inspected_at") @db.Timestamptz(6)

  returnItem      ReturnItem  @relation(fields: [returnItemId], references: [id], onDelete: Cascade)
  inspector       AdminUser   @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  @@map("return_inspection")
}

// =============================================================================
//  REVIEWS
// =============================================================================

model Review {
  id              String        @id @default(cuid())
  productId       String        @map("product_id")
  userId          String        @map("user_id")
  orderItemId     String?       @map("order_item_id")
  rating          Int                                        // 1..5
  title           String?       @db.VarChar(255)
  content         String        @db.Text
  status          ReviewStatus  @default(PENDING)
  isVerifiedPurchase Boolean    @default(false) @map("is_verified_purchase")
  helpfulCount    Int           @default(0) @map("helpful_count")
  moderatedById   String?       @map("moderated_by_id")
  moderatedAt     DateTime?     @map("moderated_at") @db.Timestamptz(6)
  moderationNote  String?       @map("moderation_note") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  moderator       AdminUser?    @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  reply           ReviewReply?
  helpfulVotes    ReviewHelpfulVote[]

  @@index([productId, status, createdAt(sort: Desc)])
  @@index([userId])
  @@index([rating])
  @@map("review")
}

model ReviewReply {
  id          String   @id @default(cuid())
  reviewId    String   @unique @map("review_id")
  authorId    String   @map("author_id")
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author      AdminUser @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@map("review_reply")
}

model ReviewHelpfulVote {
  id          String   @id @default(cuid())
  reviewId    String   @map("review_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([userId])
  @@map("review_helpful_vote")
}

