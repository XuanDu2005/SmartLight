# ============================================================================
# SmartLight — Root .env.example (used by docker-compose)
# Copy to .env.prod and fill in real values.
# NEVER commit secrets.
#
# Usage:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# ============================================================================

# ----------------------------------------------------------------------------
# Application metadata
# ----------------------------------------------------------------------------
# Image tag used by all services. Bump on each release.
APP_VERSION=1.0.0

# Global log level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Public-facing URLs (used by the API for OAuth redirects, CORS, etc.)
# ----------------------------------------------------------------------------
# Customer storefront — DNS resolves to nginx in this stack
FRONTEND_BASE_URL=https://smartlight.vn
# Admin dashboard — same nginx, different vhost
ADMIN_BASE_URL=https://admin.smartlight.vn

# API public URL (used in OAuth redirect_uri)
API_BASE_URL=https://api.smartlight.vn

# API CORS — comma-separated origins allowed to call the API directly.
# In production, traffic goes through nginx so this is just a safety net.
API_CORS_ORIGINS=https://smartlight.vn,https://admin.smartlight.vn

# ----------------------------------------------------------------------------
# Database — PostgreSQL 16
# ----------------------------------------------------------------------------
POSTGRES_USER=smartlight
POSTGRES_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
POSTGRES_DB=smartlight

# Prisma uses these (internal compose DNS name `postgres`).
DATABASE_URL=postgresql://smartlight:__REPLACE_WITH_STRONG_PASSWORD__@postgres:5432/smartlight?schema=public
DIRECT_URL=postgresql://smartlight:__REPLACE_WITH_STRONG_PASSWORD__@postgres:5432/smartlight?schema=public

# ----------------------------------------------------------------------------
# Cache + queue — Redis 7
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ----------------------------------------------------------------------------
# JWT — required for auth. Rotate these per environment.
# Generate strong values:  openssl rand -hex 64
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=__REPLACE_WITH_RANDOM_HEX_64_BYTES__
JWT_REFRESH_SECRET=__REPLACE_WITH_ANOTHER_RANDOM_HEX_64_BYTES__
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
JWT_REMEMBER_ME_TTL_SEC=2592000

# ----------------------------------------------------------------------------
# Rate limiting (per-IP, applied in NestJS ThrottlerGuard)
# ----------------------------------------------------------------------------
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=120

# ----------------------------------------------------------------------------
# OAuth (Google + Facebook) — optional
# ----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://api.smartlight.vn/v1/auth/oauth/google/callback

FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CALLBACK_URL=https://api.smartlight.vn/v1/auth/oauth/facebook/callback

# ----------------------------------------------------------------------------
# Cloudinary (image storage)
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STORAGE_PROVIDER=cloudinary

# ----------------------------------------------------------------------------
# Email (Resend) — transactional notifications
# ----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=no-reply@smartlight.vn

# ----------------------------------------------------------------------------
# Payments — VN providers
# ----------------------------------------------------------------------------
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
PAYMENT_MOMO_PARTNER_CODE=
PAYMENT_MOMO_ACCESS_KEY=
PAYMENT_MOMO_SECRET_KEY=
PAYMENT_ZALOPAY_APP_ID=
PAYMENT_ZALOPAY_KEY1=
PAYMENT_ZALOPAY_KEY2=

# ----------------------------------------------------------------------------
# Shipping carriers — VN providers
# ----------------------------------------------------------------------------
SHIPPING_GHN_TOKEN=
SHIPPING_GHTK_TOKEN=
SHIPPING_VIETTEL_POST_TOKEN=

# ----------------------------------------------------------------------------
# Monitoring (Phase 20 — Prometheus)
# ----------------------------------------------------------------------------
# Enable the /metrics endpoint on the API
METRICS_ENABLED=true
# Bearer token required to scrape /metrics (rotate per environment)
METRICS_SCRAPE_TOKEN=__REPLACE_WITH_RANDOM_STRING__

# ----------------------------------------------------------------------------
# Vite bundle-time envs (baked into the SPA bundles at build time)
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=https://smartlight.vn
VITE_ADMIN_API_BASE_URL=https://smartlight.vn
VITE_APP_NAME=SmartLight
VITE_DEFAULT_LOCALE=vi-VN
VITE_SENTRY_DSN=