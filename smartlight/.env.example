# ============================================================================
# SmartLight — Environment Variables (Example)
# Copy to .env and fill in real values. NEVER commit secrets.
# ============================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- API (NestJS) ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Database (PostgreSQL 16) ---
# For local Docker compose, use the service name 'postgres' as host.
DATABASE_URL=postgresql://smartlight:smartlight_dev_password@postgres:5432/smartlight?schema=public
DIRECT_URL=postgresql://smartlight:smartlight_dev_password@postgres:5432/smartlight?schema=public

# --- Cache / Queue (Redis) ---
# Optional in V1; code only connects if REDIS_URL is set.
REDIS_URL=redis://redis:6379

# --- Web (Customer storefront) ---
VITE_API_BASE_URL=http://localhost:4000
VITE_APP_NAME=SmartLight
VITE_DEFAULT_LOCALE=vi-VN

# --- Admin ---
VITE_ADMIN_API_BASE_URL=http://localhost:4000

# --- Auth (placeholders; rotate in production) ---
JWT_ACCESS_SECRET=change_me_min_32_characters_long_secret
JWT_REFRESH_SECRET=change_me_another_min_32_characters_long_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_REMEMBER_ME_TTL=2592000

# --- OAuth (optional in V1; required for V1.5) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:4000/v1/auth/oauth/google/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CALLBACK_URL=http://localhost:4000/v1/auth/oauth/facebook/callback

# --- Frontend base URLs (used for OAuth redirects) ---
FRONTEND_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174

# --- Rate limiting (per-IP) ---
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=20

# --- Storage (Cloudinary) — MVP ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=no-reply@smartlight.vn

# --- Payments (VN providers) — placeholders ---
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
PAYMENT_MOMO_PARTNER_CODE=
PAYMENT_MOMO_ACCESS_KEY=
PAYMENT_MOMO_SECRET_KEY=
PAYMENT_ZALOPAY_APP_ID=
PAYMENT_ZALOPAY_KEY1=
PAYMENT_ZALOPAY_KEY2=

# --- Shipping (VN carriers) — placeholders ---
SHIPPING_GHN_TOKEN=
SHIPPING_GHTK_TOKEN=
SHIPPING_VIETTEL_POST_TOKEN=

# --- Object Storage (V1 S3 / future) ---
STORAGE_PROVIDER=cloudinary
