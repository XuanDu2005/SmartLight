{
  "name": "@smartlight/config",
  "version": "0.1.0",
  "private": true,
  "description": "SmartLight environment configuration helpers (Zod-validated)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
