# =============================================================================
# SmartLight Web (Customer SPA) — production Dockerfile (multi-stage)
#
# Stage 1 (builder): install deps and produce the Vite production bundle.
# Stage 2 (runtime): nginx:alpine serving the static bundle.
#
# - Image size target: < 50 MB (alpine + nginx + hashed assets).
# - Security: writes a hardened nginx.conf that:
#       * sends security headers (CSP, X-Frame-Options, Referrer-Policy…)
#       * rate-limits requests
#       * serves /assets/* with long immutable cache
#       * SPA fallback to /index.html
#       * gzip + brotli compression
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: builder
# ---------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

# Copy lockfile + workspace manifests only (better cache hits).
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY tsconfig.base.json turbo.json ./

COPY packages/shared/package.json   ./packages/shared/
COPY packages/config/package.json  ./packages/config/
COPY packages/ui/package.json      ./packages/ui/
COPY apps/api/package.json         ./apps/api/
COPY apps/web/package.json         ./apps/web/
COPY apps/admin/package.json       ./apps/admin/

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --filter @smartlight/web... --frozen-lockfile

# Now copy source.
COPY packages ./packages
COPY apps/web ./apps/web

# Build shared/config/ui packages first — they're published as compiled
# `dist/` (their `package.json` `main` points at `dist/index.js`), so the
# web code (and tailwind.config.ts which imports `@smartlight/config`)
# can't resolve them until those dists exist.
RUN \
  pnpm --filter @smartlight/shared run build \
  && pnpm --filter @smartlight/ui run build \
  && pnpm --filter @smartlight/config run build || true

# The TypeScript build of @smartlight/config emits files at
# `dist/config/src/*.{js,d.ts}` because of how tsc infers rootDir from
# the combined input set (sibling workspaces + the package's own src).
# The package's `package.json#main` advertises `./dist/index.js`, and
# the emitted code uses relative `require("./env")` calls — so consumers
# need the entry + sibling files at the top of `dist/`. We canonicalise
# by copying the nested bundle to `dist/` (and the same for @smartlight/shared).
RUN \
  if [ -d /app/packages/config/dist/config/src ]; then \
    cp -r /app/packages/config/dist/config/src/. /app/packages/config/dist/ && \
    cp -r /app/packages/shared/dist/shared/src/. /app/packages/shared/dist/ 2>/dev/null || true; \
  fi
RUN ls /app/packages/config/dist/ | head -10; echo "---"; ls /app/packages/shared/dist/ | head -10

# Public API base URL is baked into the bundle at build time.
ARG VITE_API_BASE_URL=http://localhost:4000
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN pnpm --filter @smartlight/web run build

# ---------------------------------------------------------------------------
# Stage 2: runtime — hardened nginx serving the static bundle
# ---------------------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Install wget (HEALTHCHECK) + tini (PID 1) without bloat.
RUN apk add --no-cache wget tini \
 && rm -f /etc/nginx/conf.d/default.conf

# Drop nginx default user to a non-root `smartlight` (UID 1001) so the
# writable dirs (cache, pid, logs) are owned by the same UID we run as.
RUN addgroup -g 1001 smartlight \
  && adduser -S -G smartlight -u 1001 smartlight \
  && touch /var/run/nginx.pid \
  && chown -R smartlight:smartlight /var/cache/nginx /var/log/nginx /var/run/nginx.pid /usr/share/nginx/html

# Build stage leaves dist files owned by root (COPY --from=builder). Re-own
# everything under nginx's html directory so the non-root `smartlight`
# user that the runtime drops into can serve assets/index.html.
COPY --from=builder --chown=smartlight:smartlight /app/apps/web/dist /usr/share/nginx/html
COPY infrastructure/nginx/web.nginx.conf /etc/nginx/conf.d/default.conf

# Final safety net — re-chown in case the COPY above preserved root perms.
RUN chown -R smartlight:smartlight /usr/share/nginx/html

USER smartlight

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD wget -q --spider http://localhost/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["nginx", "-g", "daemon off;"]

LABEL org.opencontainers.image.title="SmartLight Web (Customer SPA)" \
      org.opencontainers.image.description="Customer storefront" \
      org.opencontainers.image.licenses="UNLICENSED"