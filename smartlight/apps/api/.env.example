# ============================================================================
# SmartLight — API environment template (apps/api/.env.example)
#
# Loaded automatically by `@nestjs/config` from process.cwd() at boot.
# In production this file is generated by docker-compose from the root .env.
# ============================================================================

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
API_PORT=4000

# --- Public URL ---
API_BASE_URL=https://api.smartlight.vn

# --- CORS ---
# Comma-separated list of allowed origins.
API_CORS_ORIGINS=https://smartlight.vn,https://admin.smartlight.vn

# --- Database (Prisma) ---
DATABASE_URL=postgresql://smartlight:CHANGE_ME@postgres:5432/smartlight?schema=public
DIRECT_URL=postgresql://smartlight:CHANGE_ME@postgres:5432/smartlight?schema=public

# --- Redis (optional in V1) ---
REDIS_URL=redis://redis:6379

# --- JWT ---
JWT_ACCESS_SECRET=CHANGE_ME_MIN_64_BYTES_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_MIN_64_BYTES_RANDOM
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
JWT_REMEMBER_ME_TTL_SEC=2592000

# --- Rate limiting ---
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=120

# --- Frontend URLs (used by OAuth redirect_uri) ---
FRONTEND_BASE_URL=https://smartlight.vn
ADMIN_BASE_URL=https://admin.smartlight.vn

# --- OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://api.smartlight.vn/v1/auth/oauth/google/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CALLBACK_URL=https://api.smartlight.vn/v1/auth/oauth/facebook/callback

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=no-reply@smartlight.vn

# --- Payments ---
PAYMENT_VNPAY_TMN_CODE=
PAYMENT_VNPAY_HASH_SECRET=
PAYMENT_MOMO_PARTNER_CODE=
PAYMENT_MOMO_ACCESS_KEY=
PAYMENT_MOMO_SECRET_KEY=
PAYMENT_ZALOPAY_APP_ID=
PAYMENT_ZALOPAY_KEY1=
PAYMENT_ZALOPAY_KEY2=

# --- Shipping ---
SHIPPING_GHN_TOKEN=
SHIPPING_GHTK_TOKEN=
SHIPPING_VIETTEL_POST_TOKEN=

# --- Monitoring (Prometheus) ---
METRICS_ENABLED=true
METRICS_SCRAPE_TOKEN=CHANGE_ME