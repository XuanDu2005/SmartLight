// =============================================================================
//  SmartLight Prisma Schema (AUTH-SCOPED)
// =============================================================================
//
//  The full production schema lives in:
//    docs/06-database-schema/01_PRISMA_SCHEMA.prisma
//
//  This file is the runtime schema that NestJS's PrismaService reads.
//  At the AUTH phase, only the models required by authentication / RBAC
//  are reproduced here. Future phases will add the remaining bounded
//  contexts (catalog, order, payment, ...) by extending this file.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto, pg_trgm]
}

// =============================================================================
//  AUTH-ONLY ENUMS
// =============================================================================

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED
  ANONYMIZED
}

enum AdminUserStatus {
  PENDING_MFA_SETUP
  ACTIVE
  SUSPENDED
  LOCKED
  DISABLED
}

enum RoleScope {
  SYSTEM
  CUSTOM
}

enum RefreshTokenReason {
  REFRESH
  LOGOUT
  ADMIN_REVOKE
  PASSWORD_RESET
  SECURITY
}

enum UserSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ActorType {
  USER
  ADMIN_USER
  SYSTEM
  WEBHOOK
  ANONYMOUS
}

enum AuditActionCategory {
  AUTH
  AUTHN_FAILED
  AUTHN_SUCCESS
  AUTHZ_DENIED
  USER_MANAGEMENT
  ROLE_MANAGEMENT
  RBAC_CHANGE
  DATA_EXPORT
  DATA_DELETE
}

// =============================================================================
//  USER (Customer)
// =============================================================================

model User {
  id                       String        @id @default(cuid())
  email                    String        @unique @db.Citext
  passwordHash             String?       @map("password_hash") // nullable for OAuth-only users
  provider                 AuthProvider  @default(LOCAL)
  providerId               String?       @map("provider_id")
  firstName                String?       @map("first_name") @db.VarChar(100)
  lastName                 String?       @map("last_name") @db.VarChar(100)
  phone                    String?       @db.VarChar(20)
  locale                   String        @default("vi-VN") @db.VarChar(10)
  status                   UserStatus    @default(PENDING_VERIFICATION)
  emailVerifiedAt          DateTime?     @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationToken   String?       @map("email_verification_token") @db.VarChar(128)
  passwordChangedAt        DateTime?     @map("password_changed_at") @db.Timestamptz(6)
  failedLoginCount         Int           @default(0) @map("failed_login_count")
  lockedUntil              DateTime?     @map("locked_until") @db.Timestamptz(6)
  acceptsMarketing         Boolean       @default(false) @map("accepts_marketing")
  gdprAnonymizedAt         DateTime?     @map("gdpr_anonymized_at") @db.Timestamptz(6)
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?     @map("deleted_at") @db.Timestamptz(6)

  // Role binding
  userRoles                UserRole[]

  // Sessions / refresh tokens
  refreshTokens            RefreshToken[]
  sessions                 UserSession[]

  // Cart
  carts                    Cart[]

  // Orders
  orders                   Order[]
  shipments                Shipment[]
  voucherUsages            VoucherUsage[]

  @@unique([provider, providerId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([lockedUntil])
  @@map("user")
}

// =============================================================================
//  ADMIN USER
// =============================================================================

model AdminUser {
  id                 String           @id @default(cuid())
  email              String           @unique @db.Citext
  passwordHash       String           @map("password_hash")
  displayName        String           @map("display_name") @db.VarChar(120)
  status             AdminUserStatus  @default(PENDING_MFA_SETUP)
  lastLoginAt        DateTime?        @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp        String?          @map("last_login_ip") @db.VarChar(45)
  failedLoginCount   Int              @default(0) @map("failed_login_count")
  lockedUntil        DateTime?        @map("locked_until") @db.Timestamptz(6)
  mustChangePassword Boolean          @default(false) @map("must_change_password")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamptz(6)

  adminRoles         AdminUserRole[]
  refreshTokens      RefreshToken[]
  sessions           UserSession[]
  auditLogs          AuditLog[]       @relation("AuditActorAdmin")

  @@index([status])
  @@index([lockedUntil])
  @@map("admin_user")
}

// =============================================================================
//  RBAC
// =============================================================================

model Role {
  id           String             @id @default(cuid())
  code         String             @unique @db.VarChar(60)
  displayName  String             @map("display_name") @db.VarChar(120)
  scope        RoleScope          @default(CUSTOM)
  description  String?            @db.Text
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)

  permissions  RolePermission[]
  userBindings UserRole[]
  adminBindings AdminUserRole[]

  @@map("role")
}

model Permission {
  id          String            @id @default(cuid())
  code        String            @unique @db.VarChar(100)
  category    String            @db.VarChar(60)
  displayName String            @map("display_name") @db.VarChar(160)
  description String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  roles       RolePermission[]

  @@index([category])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

// Customer-side role binding (a user has 0..N roles).
model UserRole {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  roleId       String     @map("role_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy   String?    @map("assigned_by")
  revokedAt    DateTime?  @map("revoked_at") @db.Timestamptz(6)

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

// Admin-side role binding.
model AdminUserRole {
  id           String     @id @default(cuid())
  adminUserId  String     @map("admin_user_id")
  roleId       String     @map("role_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy   String?    @map("assigned_by")
  revokedAt    DateTime?  @map("revoked_at") @db.Timestamptz(6)

  adminUser    AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([adminUserId, roleId])
  @@index([roleId])
  @@map("admin_user_role")
}

// =============================================================================
//  REFRESH TOKENS
// =============================================================================

model RefreshToken {
  id            String              @id @default(cuid())
  tokenHash     String              @unique @map("token_hash") @db.VarChar(255)
  userId        String?             @map("user_id")
  adminUserId   String?             @map("admin_user_id")
  sessionId     String?             @map("session_id")
  reason        RefreshTokenReason  @default(REFRESH)
  issuedAt      DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt     DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?           @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?             @map("revoked_reason") @db.VarChar(120)
  replacedById  String?             @unique @map("replaced_by_id")
  userAgent     String?             @map("user_agent") @db.VarChar(255)
  ip            String?             @db.VarChar(45)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser     AdminUser?          @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  session       UserSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token")
}

model UserSession {
  id            String            @id @default(cuid())
  userId        String?           @map("user_id")
  adminUserId   String?           @map("admin_user_id")
  status        UserSessionStatus @default(ACTIVE)
  ip            String            @db.VarChar(45)
  userAgent     String            @map("user_agent") @db.VarChar(255)
  deviceLabel   String?           @map("device_label") @db.VarChar(80)
  geoCountry    String?           @map("geo_country") @db.VarChar(2)
  geoCity       String?           @map("geo_city") @db.VarChar(80)
  issuedAt      DateTime          @default(now()) @map("issued_at") @db.Timestamptz(6)
  lastSeenAt    DateTime          @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt     DateTime          @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?         @map("revoked_at") @db.Timestamptz(6)

  user          User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser     AdminUser?        @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([adminUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("user_session")
}

// =============================================================================
//  CATALOG ENUMS
// =============================================================================

enum CategoryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum ProductVariantStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
  COLOR_HEX
  LIST
}

enum MediaPurpose {
  PRODUCT_IMAGE
  PRODUCT_GALLERY
  CATEGORY_BANNER
  BRAND_LOGO
  REVIEW_ATTACHMENT
  AVATAR
  STATIC_PAGE
  SUPPORT_ATTACHMENT
  EMAIL_ASSET
}

// =============================================================================
//  CATALOG MODELS
// =============================================================================

model Category {
  id           String         @id @default(cuid())
  parentId     String?        @map("parent_id")
  slug         String         @unique @db.VarChar(120)
  name         String         @db.VarChar(160)
  description  String?        @db.Text
  imageMediaId String?        @map("image_media_id")
  displayOrder Int            @default(0) @map("display_order")
  level        Int            @default(0)
  path         String         @default("/") @db.VarChar(500)
  status       CategoryStatus @default(DRAFT)
  isFeatured   Boolean        @default(false) @map("is_featured")
  taxExempt    Boolean        @default(false) @map("tax_exempt")
  metaTitle    String?        @map("meta_title") @db.VarChar(255)
  metaDesc     String?        @map("meta_description") @db.VarChar(500)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  parent     Category?       @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children   Category[]      @relation("CategoryTree")
  products   Product[]
  promotionTargets PromotionCategory[]

  @@index([parentId])
  @@index([slug])
  @@index([status, displayOrder])
  @@index([deletedAt])
  @@map("category")
}

model Brand {
  id           String      @id @default(cuid())
  slug         String      @unique @db.VarChar(120)
  name         String      @db.VarChar(160)
  description  String?     @db.Text
  logoMediaId  String?     @map("logo_media_id")
  isFeatured   Boolean     @default(false) @map("is_featured")
  status       BrandStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  products   Product[]
  promotionTargets PromotionBrand[]

  @@index([status])
  @@index([slug])
  @@map("brand")
}

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique @db.VarChar(160)
  name          String        @db.VarChar(255)
  shortDesc     String?       @map("short_description") @db.VarChar(500)
  description   String?       @db.Text
  categoryId    String        @map("category_id")
  brandId       String?       @map("brand_id")
  basePrice     Decimal       @map("base_price") @db.Decimal(20, 4)
  compareAtPrice Decimal?     @map("compare_at_price") @db.Decimal(20, 4)
  status        ProductStatus @default(DRAFT)
  isFeatured    Boolean       @default(false) @map("is_featured")
  isNewArrival  Boolean       @default(false) @map("is_new_arrival")
  publishedAt   DateTime?     @map("published_at") @db.Timestamptz(6)
  viewCount     BigInt        @default(0) @map("view_count")
  ratingAvg     Decimal       @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount   Int           @default(0) @map("rating_count")
  tags          String[]      @default([])
  metaTitle     String?       @map("meta_title") @db.VarChar(255)
  metaDesc     String?       @map("meta_description") @db.VarChar(500)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand       Brand?                @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  images      ProductImage[]
  attributes  ProductAttributeValue[]

  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([brandId, status])
  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, status])
  @@index([deletedAt])
  @@map("product")
}

model ProductVariant {
  id             String               @id @default(cuid())
  productId      String               @map("product_id")
  sku            String               @unique @db.VarChar(64)
  barcode        String?              @db.VarChar(64)
  name           String               @db.VarChar(255)
  price          Decimal              @db.Decimal(20, 4)
  compareAtPrice Decimal?             @map("compare_at_price") @db.Decimal(20, 4)
  cost           Decimal?             @db.Decimal(20, 4)
  weightGrams    Int?                 @map("weight_grams")
  lengthMm       Int?                 @map("length_mm")
  widthMm        Int?                 @map("width_mm")
  heightMm       Int?                 @map("height_mm")
  status         ProductVariantStatus @default(ACTIVE)
  isDefault      Boolean              @default(false) @map("is_default")
  displayOrder   Int                  @default(0) @map("display_order")
  attributesJson Json                 @default("{}") @map("attributes_json") @db.JsonB
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?            @map("deleted_at") @db.Timestamptz(6)

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory?
  images    ProductImage[]
  cartItems CartItem[]
  checkoutItems CheckoutItem[]
  reservationItems ReservationItem[]
  orderItems OrderItem[]
  stockMovements StockMovement[]
  adjustments InventoryAdjustment[]
  shipmentItems ShipmentItem[]
  promotionTargets PromotionProduct[]

  @@index([productId, status, displayOrder])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
  @@map("product_variant")
}

model ProductImage {
  id             String          @id @default(cuid())
  productId      String          @map("product_id")
  variantId      String?         @map("variant_id")
  mediaId        String          @map("media_id")
  altText        String?         @map("alt_text") @db.VarChar(255)
  displayOrder   Int             @default(0) @map("display_order")
  isPrimary      Boolean         @default(false) @map("is_primary")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  media   MediaFile      @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([productId, displayOrder])
  @@index([variantId])
  @@map("product_image")
}

model ProductAttribute {
  id           String           @id @default(cuid())
  code         String           @unique @db.VarChar(60)
  displayName String           @map("display_name") @db.VarChar(120)
  dataType    AttributeDataType @default(TEXT) @map("data_type")
  unit        String?           @db.VarChar(20)
  isFilterable Boolean          @default(true) @map("is_filterable")
  isRequired   Boolean           @default(false) @map("is_required")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)

  values ProductAttributeValue[]

  @@map("product_attribute")
}

model ProductAttributeValue {
  id             String           @id @default(cuid())
  productId      String           @map("product_id")
  attributeId    String           @map("attribute_id")
  valueText      String?          @map("value_text") @db.VarChar(255)
  valueNumber    Decimal?         @map("value_number") @db.Decimal(20, 4)
  valueBoolean   Boolean?         @map("value_boolean")
  valueColorHex  String?          @map("value_color_hex") @db.VarChar(7)
  valueListValue String?         @map("value_list_value") @db.VarChar(120)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute   @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_value")
}

model MediaFile {
  id               String        @id @default(cuid())
  provider         String        @default("cloudinary") @db.VarChar(40)
  providerAssetId  String        @map("provider_asset_id") @db.VarChar(255)
  url              String        @db.Text
  secureUrl        String        @map("secure_url") @db.Text
  mimeType         String        @map("mime_type") @db.VarChar(60)
  sizeBytes        BigInt        @map("size_bytes")
  width            Int?
  height           Int?
  durationSeconds  Int?          @map("duration_seconds")
  purpose          MediaPurpose?
  variantsJson     Json          @default("{}") @map("variants_json") @db.JsonB
  checksum         String?       @db.VarChar(128)
  ownerType        String?       @map("owner_type") @db.VarChar(40)
  ownerId          String?       @map("owner_id")
  createdById      String?       @map("created_by_id")
  uploadedAt       DateTime      @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  productImages ProductImage[]

  @@index([provider, providerAssetId])
  @@index([ownerType, ownerId])
  @@index([purpose, deletedAt])
  @@map("media_file")
}

model Inventory {
  id                 String   @id @default(cuid())
  productVariantId  String   @unique @map("product_variant_id")
  warehouseCode      String   @default("MAIN") @map("warehouse_code") @db.VarChar(40)
  onHand             Int      @default(0) @map("on_hand")
  reserved           Int      @default(0)
  available          Int      @default(0) @map("available")
  lowStockThreshold  Int      @default(5) @map("low_stock_threshold")
  allowBackorder     Boolean  @default(false) @map("allow_backorder")
  lastCountedAt      DateTime? @map("last_counted_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]
  adjustments     InventoryAdjustment[]

  @@unique([productVariantId, warehouseCode])
  @@index([available])
  @@index([lowStockThreshold])
  @@map("inventory")
}

model AuditLog {
  id           String              @id @default(cuid())
  category     AuditActionCategory
  action       String              @db.VarChar(120)
  entityType   String              @map("entity_type") @db.VarChar(60)
  entityId     String              @map("entity_id") @db.VarChar(64)
  actorType    ActorType           @map("actor_type")
  actorUserId  String?             @map("actor_user_id")
  actorAdminId String?             @map("actor_admin_id")
  requestId    String?             @map("request_id") @db.VarChar(64)
  ipAddress    String?             @map("ip_address") @db.VarChar(45)
  userAgent    String?             @map("user_agent") @db.VarChar(255)
  beforeJson   Json?               @map("before_json") @db.JsonB
  afterJson    Json?               @map("after_json") @db.JsonB
  metadataJson Json                @default("{}") @map("metadata_json") @db.JsonB
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  actorAdmin AdminUser? @relation("AuditActorAdmin", fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([category, createdAt(sort: Desc)])
  @@index([actorAdminId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_log")
}

// =============================================================================
//  CART & COUPON (cart-phase bounded context)
// =============================================================================

enum CartStatus {
  ACTIVE
  ABANDONED
  CHECKED_OUT
  EXPIRED
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id              String            @id @default(cuid())
  code            String            @unique @db.VarChar(40)
  description     String?           @db.Text
  discountType    CouponDiscountType @map("discount_type")
  discountValue   Decimal           @map("discount_value") @db.Decimal(12, 4)
  minCartTotal    Decimal           @default(0) @map("min_cart_total") @db.Decimal(20, 4)
  usageLimit      Int?              @map("usage_limit")
  usageCount      Int               @default(0) @map("usage_count")
  perUserLimit    Int?              @map("per_user_limit")
  validFrom       DateTime?         @map("valid_from") @db.Timestamptz(6)
  validUntil      DateTime?         @map("valid_until") @db.Timestamptz(6)
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  carts           Cart[]

  @@map("coupon")
}

model Cart {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  status             CartStatus  @default(ACTIVE)
  couponId           String?     @map("coupon_id")
  couponCode         String?     @map("coupon_code") @db.VarChar(40)
  currency           String      @default("VND") @db.VarChar(3)
  subtotal           Decimal     @default(0) @db.Decimal(20, 4)
  discountTotal      Decimal     @default(0) @map("discount_total") @db.Decimal(20, 4)
  taxTotal           Decimal     @default(0) @map("tax_total") @db.Decimal(20, 4)
  shippingTotal      Decimal     @default(0) @map("shipping_total") @db.Decimal(20, 4)
  estimatedShipping  Decimal     @default(0) @map("estimated_shipping") @db.Decimal(20, 4)
  grandTotal         Decimal     @default(0) @map("grand_total") @db.Decimal(20, 4)
  itemCount          Int         @default(0) @map("item_count")
  selectedItemCount  Int         @default(0) @map("selected_item_count")
  isItemSelected     Boolean     @default(false) @map("is_item_selected")
  notes              String?     @db.VarChar(500)
  promotionSnapshot  Json        @default("{}") @map("promotion_snapshot") @db.JsonB
  expiresAt          DateTime?   @map("expires_at") @db.Timestamptz(6)
  lastActivityAt     DateTime    @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz(6)

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon             Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              CartItem[]
  checkoutSessions   CheckoutSession[]
  reservations       StockReservation[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([lastActivityAt])
  @@map("cart")
}

model CartItem {
  id                    String        @id @default(cuid())
  cartId                String        @map("cart_id")
  productVariantId      String        @map("product_variant_id")
  quantity              Int
  unitPrice             Decimal       @map("unit_price") @db.Decimal(20, 4)
  discountSnapshot      Decimal       @default(0) @map("discount_snapshot") @db.Decimal(20, 4)
  subtotal              Decimal       @db.Decimal(20, 4)
  productNameSnapshot   String        @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot   String        @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot           String        @map("sku_snapshot") @db.VarChar(64)
  productSlug           String        @map("product_slug") @db.VarChar(160)
  productImageUrl       String?       @map("product_image_url") @db.VarChar(500)
  color                 String?       @db.VarChar(60)
  size                  String?       @db.VarChar(60)
  isSelected            Boolean       @default(true) @map("is_selected")
  availableStockAtAdd   Int?          @map("available_stock_at_add")
  notes                 String?       @db.VarChar(500)
  promotionSnapshot     Json          @default("{}") @map("promotion_snapshot") @db.JsonB
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz(6)

  cart                  Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant               ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([cartId, productVariantId])
  @@index([productVariantId])
  @@index([deletedAt])
  @@map("cart_item")
}

// =============================================================================
//  CHECKOUT (checkout-phase bounded context)
// =============================================================================

enum CheckoutSessionStatus {
  CREATED
  PENDING_RESERVATION
  RESERVED
  EXPIRED
  CANCELLED
  COMPLETED
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONFIRMED
  EXPIRED
}

model StockReservation {
  id                 String                  @id @default(cuid())
  checkoutSessionId  String?                @unique @map("checkout_session_id")
  cartId             String?               @map("cart_id")
  userId             String?               @map("user_id")
  status             StockReservationStatus @default(ACTIVE)
  expiresAt          DateTime              @map("expires_at") @db.Timestamptz(6)
  consumedAt         DateTime?             @map("consumed_at") @db.Timestamptz(6)
  releasedAt         DateTime?             @map("released_at") @db.Timestamptz(6)
  releasedReason     String?               @map("released_reason") @db.VarChar(80)
  metadataJson       Json                  @default("{}") @map("metadata_json") @db.JsonB
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  session            CheckoutSession?      @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)
  cart               Cart?                @relation(fields: [cartId], references: [id], onDelete: Cascade)
  items              ReservationItem[]

  @@index([checkoutSessionId])
  @@index([cartId])
  @@index([userId])
  @@index([status, expiresAt])
  @@map("stock_reservation")
}

model ReservationItem {
  id                 String            @id @default(cuid())
  reservationId     String            @map("reservation_id")
  productVariantId  String            @map("product_variant_id")
  quantity           Int
  reservedAt        DateTime          @default(now()) @map("reserved_at") @db.Timestamptz(6)

  reservation       StockReservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  variant           ProductVariant    @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([reservationId, productVariantId])
  @@index([productVariantId])
  @@map("reservation_item")
}

model CheckoutSession {
  id                    String                  @id @default(cuid())
  cartId               String                  @map("cart_id")
  userId               String                  @map("user_id")
  status               CheckoutSessionStatus   @default(CREATED)

  // Shipping address (denormalised for snapshot isolation)
  shippingFullName    String?                 @map("shipping_full_name") @db.VarChar(120)
  shippingPhone        String?                 @map("shipping_phone") @db.VarChar(20)
  shippingProvince     String?                 @map("shipping_province") @db.VarChar(80)
  shippingDistrict     String?                 @map("shipping_district") @db.VarChar(80)
  shippingWard         String?                 @map("shipping_ward") @db.VarChar(80)
  shippingDetail      String?                 @map("shipping_detail") @db.VarChar(255)

  // Billing address (optional, defaults to shipping)
  billingFullName     String?                 @map("billing_full_name") @db.VarChar(120)
  billingPhone        String?                 @map("billing_phone") @db.VarChar(20)
  billingProvince     String?                 @map("billing_province") @db.VarChar(80)
  billingDistrict     String?                 @map("billing_district") @db.VarChar(80)
  billingWard         String?                 @map("billing_ward") @db.VarChar(80)
  billingDetail       String?                 @map("billing_detail") @db.VarChar(255)

  // Totals
  currency             String                  @default("VND") @db.VarChar(3)
  subtotal             Decimal                 @default(0) @db.Decimal(20, 4)
  discountAmount       Decimal                 @default(0) @map("discount_amount") @db.Decimal(20, 4)
  shippingFee          Decimal                 @default(0) @map("shipping_fee") @db.Decimal(20, 4)
  taxAmount            Decimal                 @default(0) @map("tax_amount") @db.Decimal(20, 4)
  grandTotal           Decimal                 @default(0) @map("grand_total") @db.Decimal(20, 4)

  // Shipping method placeholder
  shippingMethodId    String?                 @map("shipping_method_id")
  shippingMethodName  String?                 @map("shipping_method_name") @db.VarChar(120)

  // Coupon placeholder
  couponId            String?                 @map("coupon_id")
  couponCode          String?                 @map("coupon_code") @db.VarChar(40)

  // Idempotency
  idempotencyKey      String?                 @unique @map("idempotency_key") @db.VarChar(120)

  expiresAt            DateTime                @map("expires_at") @db.Timestamptz(6)
  completedAt          DateTime?               @map("completed_at") @db.Timestamptz(6)
  cancelledAt          DateTime?               @map("cancelled_at") @db.Timestamptz(6)
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart                 Cart                  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  reservation          StockReservation?
  items                CheckoutItem[]

  @@index([userId, status])
  @@index([cartId])
  @@index([status, expiresAt])
  @@map("checkout_session")
}

model CheckoutItem {
  id                     String        @id @default(cuid())
  sessionId             String        @map("session_id")
  productVariantId       String        @map("product_variant_id")
  quantity               Int
  // Price snapshots (immutable once checkout starts)
  unitPriceSnapshot      Decimal       @map("unit_price") @db.Decimal(20, 4)
  lineSubtotalSnapshot   Decimal       @map("line_subtotal") @db.Decimal(20, 4)
  taxAmountSnapshot      Decimal       @default(0) @map("tax_amount_snapshot") @db.Decimal(20, 4)
  productNameSnapshot    String        @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot    String        @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot            String        @map("sku_snapshot") @db.VarChar(64)
  productSlug            String        @map("product_slug") @db.VarChar(160)
  productImageUrl        String?       @map("product_image_url") @db.VarChar(500)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  session               CheckoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant               ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([sessionId, productVariantId])
  @@index([productVariantId])
  @@map("checkout_item")
}

// =============================================================================
//  ORDER MANAGEMENT
// =============================================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PACKED
  SHIPPED
  DELIVERING
  DELIVERED
  CANCELLED
  REFUNDED
  RETURN_REQUESTED
  RETURNED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

model Order {
  id                  String              @id @default(cuid())
  orderNumber         String              @unique @db.VarChar(40)
  userId              String              @map("user_id")
  checkoutSessionId   String?             @unique @map("checkout_session_id")
  cartId              String?             @map("cart_id")
  reservationId       String?             @map("reservation_id")
  status              OrderStatus         @default(PENDING_PAYMENT)
  paymentStatus       OrderPaymentStatus  @default(UNPAID) @map("payment_status")
  currency            String              @default("VND") @db.VarChar(3)
  locale              String              @default("vi-VN") @db.VarChar(10)

  // Totals (snapshot from checkout)
  subtotal            Decimal             @default(0) @db.Decimal(20, 4)
  discountAmount      Decimal             @default(0) @map("discount_amount") @db.Decimal(20, 4)
  shippingFee         Decimal             @default(0) @map("shipping_fee") @db.Decimal(20, 4)
  taxAmount           Decimal             @default(0) @map("tax_amount") @db.Decimal(20, 4)
  grandTotal          Decimal             @default(0) @map("grand_total") @db.Decimal(20, 4)

  // Shipping address snapshot
  shippingFullName    String?             @map("shipping_full_name") @db.VarChar(120)
  shippingPhone       String?             @map("shipping_phone") @db.VarChar(20)
  shippingProvince    String?             @map("shipping_province") @db.VarChar(80)
  shippingDistrict    String?             @map("shipping_district") @db.VarChar(80)
  shippingWard        String?             @map("shipping_ward") @db.VarChar(80)
  shippingDetail      String?             @map("shipping_detail") @db.VarChar(255)

  // Billing address snapshot
  billingFullName     String?             @map("billing_full_name") @db.VarChar(120)
  billingPhone        String?             @map("billing_phone") @db.VarChar(20)
  billingProvince     String?             @map("billing_province") @db.VarChar(80)
  billingDistrict     String?             @map("billing_district") @db.VarChar(80)
  billingWard         String?             @map("billing_ward") @db.VarChar(80)
  billingDetail       String?             @map("billing_detail") @db.VarChar(255)

  // Customer notes (immutable after creation)
  customerNotes       String?             @map("customer_notes") @db.Text

  // Cancellation
  cancelledAt         DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelReason        String?             @map("cancel_reason") @db.VarChar(120)
  cancelledById       String?             @map("cancelled_by_id")

  // Payment timestamps
  paidAt              DateTime?           @map("paid_at") @db.Timestamptz(6)

  // Coupon placeholder
  couponCode          String?             @map("coupon_code") @db.VarChar(40)

  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?           @map("deleted_at") @db.Timestamptz(6)

  user                User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  items               OrderItem[]
  statusHistory       OrderStatusHistory[]
  payments            Payment[]
  shipments           Shipment[]
  voucherUsages       VoucherUsage[]

  @@index([orderNumber])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([reservationId])
  @@map("order")
}

model OrderItem {
  id                     String        @id @default(cuid())
  orderId                String        @map("order_id")
  productVariantId       String        @map("product_variant_id")
  quantity               Int
  // Immutable price snapshot
  unitPriceSnapshot      Decimal       @map("unit_price") @db.Decimal(20, 4)
  lineSubtotalSnapshot   Decimal       @map("line_subtotal") @db.Decimal(20, 4)
  taxAmountSnapshot      Decimal       @default(0) @map("tax_amount_snapshot") @db.Decimal(20, 4)
  // Product info snapshot
  productNameSnapshot    String        @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot    String        @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot            String        @map("sku_snapshot") @db.VarChar(64)
  productSlugSnapshot    String        @map("product_slug_snapshot") @db.VarChar(160)
  imageSnapshotUrl       String?       @map("image_snapshot_url") @db.VarChar(500)
  weightGramsSnapshot    Int?          @map("weight_grams_snapshot")
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  order                  Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant                ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([orderId, productVariantId])
  @@index([productVariantId])
  @@map("order_item")
}

model OrderStatusHistory {
  id                String      @id @default(cuid())
  orderId           String      @map("order_id")
  fromStatus        OrderStatus? @map("from_status")
  toStatus          OrderStatus @map("to_status")
  changedByType     String      @default("SYSTEM") @map("changed_by_type") @db.VarChar(20)
  changedById       String?     @map("changed_by_id")
  changedByName     String?     @map("changed_by_name") @db.VarChar(120)
  reason            String?     @db.VarChar(255)
  metadataJson      Json        @default("{}") @map("metadata_json") @db.JsonB
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_status_history")
}

// =============================================================================
//  PAYMENT
// =============================================================================

enum PaymentStatus {
  CREATED
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MOMO
  VNPAY
  PAYPAL
}

enum PaymentTransactionStatus {
  INITIATED
  SUCCESS
  FAILED
  REVERSED
}

enum PaymentWebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

model Payment {
  id                  String                 @id @default(cuid())
  orderId            String                  @unique @map("order_id")
  userId              String                 @map("user_id")
  provider            PaymentProvider
  status              PaymentStatus           @default(CREATED)
  amount              Decimal                @db.Decimal(20, 4)
  currency            String                 @default("VND") @db.VarChar(3)
  providerTxnId       String?                @map("provider_txn_id") @db.VarChar(255)
  providerReference   String?                @map("provider_reference") @db.VarChar(255)
  idempotencyKey      String?                @unique @map("idempotency_key") @db.VarChar(120)
  checkoutUrl         String?                @map("checkout_url") @db.VarChar(1024)
  failureReason       String?                @map("failure_reason") @db.VarChar(255)
  expiresAt           DateTime?              @map("expires_at") @db.Timestamptz(6)
  authorizedAt        DateTime?              @map("authorized_at") @db.Timestamptz(6)
  succeededAt         DateTime?              @map("succeeded_at") @db.Timestamptz(6)
  failedAt            DateTime?              @map("failed_at") @db.Timestamptz(6)
  cancelledAt         DateTime?              @map("cancelled_at") @db.Timestamptz(6)
  metadataJson        Json                   @default("{}") @map("metadata_json") @db.JsonB
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions        PaymentTransaction[]
  webhookLogs         PaymentWebhookLog[]

  @@index([userId, status])
  @@index([orderId])
  @@index([provider, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([providerTxnId])
  @@index([createdAt(sort: Desc)])
  @@map("payment")
}

model PaymentTransaction {
  id                String                      @id @default(cuid())
  paymentId        String                       @map("payment_id")
  type              String                      @db.VarChar(40)
  status            PaymentTransactionStatus    @default(INITIATED)
  amount            Decimal                     @db.Decimal(20, 4)
  providerCode      String?                     @map("provider_code") @db.VarChar(80)
  providerMessage   String?                     @map("provider_message") @db.Text
  providerTxnId     String?                     @map("provider_txn_id") @db.VarChar(255)
  rawResponseJson   Json?                       @map("raw_response_json") @db.JsonB
  createdAt         DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  payment           Payment                     @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, providerTxnId])
  @@index([paymentId, createdAt(sort: Desc)])
  @@index([type])
  @@map("payment_transaction")
}

model PaymentWebhookLog {
  id                String                    @id @default(cuid())
  paymentId         String?                   @map("payment_id")
  provider          PaymentProvider
  eventId           String                    @map("event_id") @db.VarChar(255)
  eventType         String                    @map("event_type") @db.VarChar(80)
  status            PaymentWebhookEventStatus @default(RECEIVED)
  payloadJson       Json                      @map("payload_json") @db.JsonB
  signature         String?                   @db.VarChar(1024)
  processedAt       DateTime?                 @map("processed_at") @db.Timestamptz(6)
  errorMessage      String?                   @map("error_message") @db.Text
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  payment           Payment?                  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("payment_webhook_log")
}

// =============================================================================
//  INVENTORY MANAGEMENT
// =============================================================================

enum StockMovementType {
  IMPORT
  EXPORT
  SALE
  RESERVATION
  RELEASE
  RETURN
  ADJUSTMENT
}

enum InventoryAdjustmentReason {
  COUNT_CORRECTION
  DAMAGE
  LOSS
  RECEIVING
  TRANSFER
  INITIAL_STOCK
  OTHER
}

model StockMovement {
  id                String             @id @default(cuid())
  inventoryId       String             @map("inventory_id")
  productVariantId  String             @map("product_variant_id")
  type              StockMovementType
  quantity          Int                // signed: positive = in, negative = out
  onHandAfter       Int                @map("on_hand_after")
  reservedAfter     Int                @map("reserved_after") @default(0)
  reason            String?            @db.VarChar(255)
  referenceType     String?            @map("reference_type") @db.VarChar(60)
  referenceId       String?            @map("reference_id")
  createdByType     ActorType          @default(SYSTEM) @map("created_by_type")
  createdById       String?            @map("created_by_id")
  metadataJson      Json               @default("{}") @map("metadata_json") @db.JsonB
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  inventory         Inventory           @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  variant           ProductVariant      @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([inventoryId, createdAt(sort: Desc)])
  @@index([productVariantId, createdAt(sort: Desc)])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt(sort: Desc)])
  @@map("stock_movement")
}

model InventoryAdjustment {
  id                String                      @id @default(cuid())
  inventoryId       String                      @map("inventory_id")
  productVariantId  String                      @map("product_variant_id")
  quantityDelta     Int                         @map("quantity_delta")
  onHandAfter      Int                         @map("on_hand_after")
  reason            InventoryAdjustmentReason
  note              String?                     @db.Text
  referenceType     String?                     @map("reference_type") @db.VarChar(60)
  referenceId       String?                     @map("reference_id")
  createdByType     ActorType                   @default(ADMIN_USER) @map("created_by_type")
  createdById       String?                     @map("created_by_id")
  createdAt         DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  inventory         Inventory                   @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  variant           ProductVariant              @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([inventoryId, createdAt(sort: Desc)])
  @@index([productVariantId, createdAt(sort: Desc)])
  @@map("inventory_adjustment")
}

// =============================================================================
//  SHIPPING
// =============================================================================

enum ShipmentStatus {
  CREATED
  WAITING_PICKUP
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNING
  RETURNED
  CANCELLED
}

enum ShippingProvider {
  GHN
  GHTK
  VIETTEL_POST
  AHAMOVE
  GRAB_EXPRESS
}

enum ShipmentEventType {
  CREATED
  STATUS_CHANGED
  TRACKING_UPDATED
  DELIVERED
  RETURNED
  FAILED
}

model Shipment {
  id                    String                @id @default(cuid())
  shipmentNumber        String                @unique @db.VarChar(40)
  orderId               String                @unique @map("order_id")
  userId                String                @map("user_id")
  provider              ShippingProvider
  status                ShipmentStatus        @default(CREATED)
  trackingNumber        String?               @unique @map("tracking_number") @db.VarChar(120)
  shippingFee           Decimal               @map("shipping_fee") @db.Decimal(20, 4)
  codAmount             Decimal               @default(0) @map("cod_amount") @db.Decimal(20, 4)
  weightGrams           Int                   @map("weight_grams")
  lengthMm              Int?                  @map("length_mm")
  widthMm               Int?                  @map("width_mm")
  heightMm              Int?                  @map("height_mm")
  // Shipping address snapshot
  shipToFullName        String                @map("ship_to_full_name") @db.VarChar(120)
  shipToPhone           String                @map("ship_to_phone") @db.VarChar(20)
  shipToProvince        String                @map("ship_to_province") @db.VarChar(80)
  shipToDistrict        String                @map("ship_to_district") @db.VarChar(80)
  shipToWard            String?               @map("ship_to_ward") @db.VarChar(80)
  shipToDetail          String                @map("ship_to_detail") @db.VarChar(255)
  // Provider response
  providerOrderCode     String?               @map("provider_order_code") @db.VarChar(120)
  labelUrl              String?               @map("label_url") @db.Text
  estimatedDeliveryAt   DateTime?             @map("estimated_delivery_at") @db.Timestamptz(6)
  shippedAt             DateTime?             @map("shipped_at") @db.Timestamptz(6)
  pickedUpAt            DateTime?             @map("picked_up_at") @db.Timestamptz(6)
  deliveredAt           DateTime?             @map("delivered_at") @db.Timestamptz(6)
  returnedAt            DateTime?             @map("returned_at") @db.Timestamptz(6)
  cancelledAt           DateTime?             @map("cancelled_at") @db.Timestamptz(6)
  failureReason         String?               @map("failure_reason") @db.VarChar(255)
  notes                 String?               @db.Text
  metadataJson          Json                  @default("{}") @map("metadata_json") @db.JsonB
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  order                 Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  items                 ShipmentItem[]
  history               ShipmentHistory[]

  @@index([userId, status])
  @@index([orderId])
  @@index([provider, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([trackingNumber])
  @@index([createdAt(sort: Desc)])
  @@map("shipment")
}

model ShipmentItem {
  id                  String         @id @default(cuid())
  shipmentId          String         @map("shipment_id")
  orderItemId         String?        @map("order_item_id")
  productVariantId    String         @map("product_variant_id")
  quantity            Int
  // Immutable snapshots
  productNameSnapshot String         @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot String         @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot         String         @map("sku_snapshot") @db.VarChar(64)
  weightGramsSnapshot Int            @map("weight_grams_snapshot")
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  shipment            Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  variant             ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, productVariantId])
  @@index([productVariantId])
  @@map("shipment_item")
}

model ShipmentHistory {
  id                String            @id @default(cuid())
  shipmentId        String            @map("shipment_id")
  event             ShipmentEventType
  oldStatus         ShipmentStatus?   @map("old_status")
  newStatus         ShipmentStatus?   @map("new_status")
  actorType         String            @default("SYSTEM") @map("actor_type") @db.VarChar(20)
  actorId           String?           @map("actor_id")
  actorName         String?           @map("actor_name") @db.VarChar(120)
  message           String?           @db.VarChar(500)
  location          String?           @db.VarChar(120)
  metadataJson      Json              @default("{}") @map("metadata_json") @db.JsonB
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  shipment          Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt(sort: Desc)])
  @@index([event])
  @@map("shipment_history")
}

model ShippingWebhookLog {
  id                String           @id @default(cuid())
  provider          ShippingProvider
  eventId           String           @map("event_id") @db.VarChar(255)
  eventType         String?          @map("event_type") @db.VarChar(80)
  payloadJson       Json             @map("payload_json") @db.JsonB
  signature         String?          @db.VarChar(1024)
  processed         Boolean          @default(false)
  processedAt       DateTime?        @map("processed_at") @db.Timestamptz(6)
  errorMessage      String?          @map("error_message") @db.Text
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([provider, eventId])
  @@index([provider, processed])
  @@index([createdAt(sort: Desc)])
  @@map("shipping_webhook_log")
}

model ShippingFeeCache {
  id                String          @id @default(cuid())
  provider          ShippingProvider
  originProvince    String          @map("origin_province") @db.VarChar(80)
  originDistrict    String          @map("origin_district") @db.VarChar(80)
  destProvince      String          @map("dest_province") @db.VarChar(80)
  destDistrict      String          @map("dest_district") @db.VarChar(80)
  weightGrams       Int             @map("weight_grams")
  fee               Decimal         @db.Decimal(20, 4)
  currency          String          @default("VND") @db.VarChar(3)
  rawResponseJson   Json?           @map("raw_response_json") @db.JsonB
  expiresAt         DateTime        @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([provider, originProvince, originDistrict, destProvince, destDistrict, weightGrams])
  @@index([expiresAt])
  @@map("shipping_fee_cache")
}

// =============================================================================
//  PROMOTIONS
// =============================================================================

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  FLASH_SALE
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  EXPIRED
  DISABLED
  ARCHIVED
}

enum VoucherType {
  PUBLIC
  PRIVATE
  AUTO_APPLY
}

enum DiscountScope {
  ORDER
  PRODUCT
  CATEGORY
  BRAND
}

enum UsageLimitType {
  UNLIMITED
  PER_USER
  TOTAL
}

model Promotion {
  id                  String            @id @default(cuid())
  name                String            @db.VarChar(120)
  description         String?           @db.VarChar(1000)
  type                PromotionType
  status              PromotionStatus   @default(DRAFT)
  scope               DiscountScope     @default(ORDER)
  discountValue       Decimal           @map("discount_value") @db.Decimal(20, 4)
  minimumOrderValue   Decimal           @default(0) @map("minimum_order_value") @db.Decimal(20, 4)
  maximumDiscount     Decimal?          @map("maximum_discount") @db.Decimal(20, 4)
  startAt             DateTime          @map("start_at") @db.Timestamptz(6)
  endAt               DateTime          @map("end_at") @db.Timestamptz(6)
  priority            Int               @default(0)
  stackable           Boolean           @default(false)
  usageLimitType      UsageLimitType    @default(TOTAL) @map("usage_limit_type")
  usageLimit          Int?              @map("usage_limit")
  perUserLimit        Int?              @map("per_user_limit")
  usedCount           Int               @default(0) @map("used_count")
  isFreeShipping      Boolean           @default(false) @map("is_free_shipping")
  flashSaleStock      Int?              @map("flash_sale_stock")
  flashSaleSold       Int               @default(0) @map("flash_sale_sold")
  bannerMediaUrl      String?           @map("banner_media_url") @db.VarChar(1024)
  metadataJson        Json              @default("{}") @map("metadata_json") @db.JsonB
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime?         @map("archived_at") @db.Timestamptz(6)

  vouchers            Voucher[]
  productTargets      PromotionProduct[]
  categoryTargets     PromotionCategory[]
  brandTargets        PromotionBrand[]
  auditLogs           PromotionAuditLog[]

  @@index([status, startAt])
  @@index([status, endAt])
  @@index([type, status])
  @@index([priority])
  @@index([createdAt(sort: Desc)])
  @@map("promotion")
}

model PromotionProduct {
  id                String         @id @default(cuid())
  promotionId       String         @map("promotion_id")
  productVariantId  String         @map("product_variant_id")

  promotion         Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  variant           ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productVariantId])
  @@index([productVariantId])
  @@map("promotion_product")
}

model PromotionCategory {
  id                String         @id @default(cuid())
  promotionId       String         @map("promotion_id")
  categoryId        String         @map("category_id")

  promotion         Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category          Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promotionId, categoryId])
  @@index([categoryId])
  @@map("promotion_category")
}

model PromotionBrand {
  id                String         @id @default(cuid())
  promotionId       String         @map("promotion_id")
  brandId           String         @map("brand_id")

  promotion         Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  brand             Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([promotionId, brandId])
  @@index([brandId])
  @@map("promotion_brand")
}

model Voucher {
  id                String         @id @default(cuid())
  promotionId       String         @map("promotion_id")
  code              String         @unique @db.VarChar(64)
  type              VoucherType    @default(PUBLIC)
  status            PromotionStatus @default(ACTIVE)
  usageLimitType    UsageLimitType @default(TOTAL) @map("usage_limit_type")
  usageLimit        Int?           @map("usage_limit")
  perUserLimit      Int?           @map("per_user_limit")
  usedCount         Int            @default(0) @map("used_count")
  expiresAt         DateTime       @map("expires_at") @db.Timestamptz(6)
  firstOrderOnly    Boolean        @default(false) @map("first_order_only")
  metadataJson      Json           @default("{}") @map("metadata_json") @db.JsonB
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  promotion         Promotion      @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  usages            VoucherUsage[]

  @@index([promotionId])
  @@index([status, expiresAt])
  @@map("voucher")
}

model VoucherUsage {
  id                String         @id @default(cuid())
  voucherId         String         @map("voucher_id")
  userId            String         @map("user_id")
  orderId           String         @map("order_id")
  promotionId       String         @map("promotion_id")
  discountAmount    Decimal        @map("discount_amount") @db.Decimal(20, 4)
  usedAt            DateTime       @default(now()) @map("used_at") @db.Timestamptz(6)

  voucher           Voucher        @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  user              User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([voucherId, orderId])
  @@index([userId])
  @@index([orderId])
  @@index([promotionId])
  @@map("voucher_usage")
}

model PromotionAuditLog {
  id                String         @id @default(cuid())
  promotionId       String         @map("promotion_id")
  action            String         @db.VarChar(60)
  payloadJson       Json           @map("payload_json") @db.JsonB
  actorType         String         @default("ADMIN_USER") @map("actor_type") @db.VarChar(20)
  actorId           String?        @map("actor_id")
  actorName         String?        @map("actor_name") @db.VarChar(120)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  promotion         Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId, createdAt(sort: Desc)])
  @@index([action])
  @@map("promotion_audit_log")
}

// =============================================================================
//  NOTIFICATIONS
// =============================================================================

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum NotificationEventType {
  USER_REGISTERED
  USER_VERIFIED
  PASSWORD_RESET
  ORDER_CREATED
  ORDER_PAID
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  PAYMENT_FAILED
  SHIPMENT_RETURNED
  PROMOTION_PUBLISHED
  LOW_STOCK_ALERT
  ADMIN_GENERIC
  CUSTOM
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  code            String              @unique @db.VarChar(80)
  eventType       NotificationEventType @map("event_type")
  channel         NotificationChannel
  locale          String              @default("vi-VN") @db.VarChar(10)
  subjectTemplate String?             @map("subject_template") @db.VarChar(255)
  bodyTemplate    String              @map("body_template") @db.Text
  variablesJson   Json                @default("[]") @map("variables_json") @db.JsonB
  isActive        Boolean             @default(true) @map("is_active")
  version         Int                 @default(1)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz(6)

  notifications Notification[]

  @@unique([code, channel, locale])
  @@index([eventType, channel, isActive])
  @@map("notification_template")
}

model Notification {
  id              String                @id @default(cuid())
  templateId      String?               @map("template_id")
  eventType       NotificationEventType @map("event_type")
  channel         NotificationChannel
  recipientUserId String?               @map("recipient_user_id")
  recipientEmail  String?               @map("recipient_email") @db.VarChar(255)
  recipientPhone  String?               @map("recipient_phone") @db.VarChar(30)
  subject         String?               @db.VarChar(255)
  body            String                @db.Text
  variablesJson   Json                  @default("{}") @map("variables_json") @db.JsonB
  status          NotificationStatus    @default(QUEUED)
  attempts        Int                   @default(0)
  lastError       String?               @map("last_error") @db.Text
  providerMessageId String?             @map("provider_message_id") @db.VarChar(160)
  queuedAt        DateTime              @default(now()) @map("queued_at") @db.Timestamptz(6)
  sentAt          DateTime?             @map("sent_at") @db.Timestamptz(6)
  nextAttemptAt   DateTime?             @map("next_attempt_at") @db.Timestamptz(6)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([status, queuedAt])
  @@index([eventType, status])
  @@index([recipientUserId])
  @@index([recipientEmail])
  @@map("notification")
}

// =============================================================================
//  END OF CATALOG
