// =============================================================================
//  SmartLight Prisma Schema (AUTH-SCOPED)
// =============================================================================
//
//  The full production schema lives in:
//    docs/06-database-schema/01_PRISMA_SCHEMA.prisma
//
//  This file is the runtime schema that NestJS's PrismaService reads.
//  At the AUTH phase, only the models required by authentication / RBAC
//  are reproduced here. Future phases will add the remaining bounded
//  contexts (catalog, order, payment, ...) by extending this file.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto, pg_trgm]
}

// =============================================================================
//  AUTH-ONLY ENUMS
// =============================================================================

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED
  ANONYMIZED
}

enum AdminUserStatus {
  PENDING_MFA_SETUP
  ACTIVE
  SUSPENDED
  LOCKED
  DISABLED
}

enum RoleScope {
  SYSTEM
  CUSTOM
}

enum RefreshTokenReason {
  REFRESH
  LOGOUT
  ADMIN_REVOKE
  PASSWORD_RESET
  SECURITY
}

enum UserSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ActorType {
  USER
  ADMIN_USER
  SYSTEM
  WEBHOOK
  ANONYMOUS
}

enum AuditActionCategory {
  AUTH
  AUTHN_FAILED
  AUTHN_SUCCESS
  AUTHZ_DENIED
  USER_MANAGEMENT
  ROLE_MANAGEMENT
  RBAC_CHANGE
  DATA_EXPORT
  DATA_DELETE
}

// =============================================================================
//  USER (Customer)
// =============================================================================

model User {
  id                       String        @id @default(cuid())
  email                    String        @unique @db.Citext
  passwordHash             String?       @map("password_hash") // nullable for OAuth-only users
  provider                 AuthProvider  @default(LOCAL)
  providerId               String?       @map("provider_id")
  firstName                String?       @map("first_name") @db.VarChar(100)
  lastName                 String?       @map("last_name") @db.VarChar(100)
  phone                    String?       @db.VarChar(20)
  locale                   String        @default("vi-VN") @db.VarChar(10)
  status                   UserStatus    @default(PENDING_VERIFICATION)
  emailVerifiedAt          DateTime?     @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationToken   String?       @map("email_verification_token") @db.VarChar(128)
  passwordChangedAt        DateTime?     @map("password_changed_at") @db.Timestamptz(6)
  failedLoginCount         Int           @default(0) @map("failed_login_count")
  lockedUntil              DateTime?     @map("locked_until") @db.Timestamptz(6)
  acceptsMarketing         Boolean       @default(false) @map("accepts_marketing")
  gdprAnonymizedAt         DateTime?     @map("gdpr_anonymized_at") @db.Timestamptz(6)
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?     @map("deleted_at") @db.Timestamptz(6)

  // Role binding
  userRoles                UserRole[]

  // Sessions / refresh tokens
  refreshTokens            RefreshToken[]
  sessions                 UserSession[]

  // Cart
  carts                    Cart[]

  @@unique([provider, providerId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([lockedUntil])
  @@map("user")
}

// =============================================================================
//  ADMIN USER
// =============================================================================

model AdminUser {
  id                 String           @id @default(cuid())
  email              String           @unique @db.Citext
  passwordHash       String           @map("password_hash")
  displayName        String           @map("display_name") @db.VarChar(120)
  status             AdminUserStatus  @default(PENDING_MFA_SETUP)
  lastLoginAt        DateTime?        @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp        String?          @map("last_login_ip") @db.VarChar(45)
  failedLoginCount   Int              @default(0) @map("failed_login_count")
  lockedUntil        DateTime?        @map("locked_until") @db.Timestamptz(6)
  mustChangePassword Boolean          @default(false) @map("must_change_password")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamptz(6)

  adminRoles         AdminUserRole[]
  refreshTokens      RefreshToken[]
  sessions           UserSession[]
  auditLogs          AuditLog[]       @relation("AuditActorAdmin")

  @@index([status])
  @@index([lockedUntil])
  @@map("admin_user")
}

// =============================================================================
//  RBAC
// =============================================================================

model Role {
  id           String             @id @default(cuid())
  code         String             @unique @db.VarChar(60)
  displayName  String             @map("display_name") @db.VarChar(120)
  scope        RoleScope          @default(CUSTOM)
  description  String?            @db.Text
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)

  permissions  RolePermission[]
  userBindings UserRole[]
  adminBindings AdminUserRole[]

  @@map("role")
}

model Permission {
  id          String            @id @default(cuid())
  code        String            @unique @db.VarChar(100)
  category    String            @db.VarChar(60)
  displayName String            @map("display_name") @db.VarChar(160)
  description String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  roles       RolePermission[]

  @@index([category])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

// Customer-side role binding (a user has 0..N roles).
model UserRole {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  roleId       String     @map("role_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy   String?    @map("assigned_by")
  revokedAt    DateTime?  @map("revoked_at") @db.Timestamptz(6)

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

// Admin-side role binding.
model AdminUserRole {
  id           String     @id @default(cuid())
  adminUserId  String     @map("admin_user_id")
  roleId       String     @map("role_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy   String?    @map("assigned_by")
  revokedAt    DateTime?  @map("revoked_at") @db.Timestamptz(6)

  adminUser    AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([adminUserId, roleId])
  @@index([roleId])
  @@map("admin_user_role")
}

// =============================================================================
//  REFRESH TOKENS
// =============================================================================

model RefreshToken {
  id            String              @id @default(cuid())
  tokenHash     String              @unique @map("token_hash") @db.VarChar(255)
  userId        String?             @map("user_id")
  adminUserId   String?             @map("admin_user_id")
  sessionId     String?             @map("session_id")
  reason        RefreshTokenReason  @default(REFRESH)
  issuedAt      DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt     DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?           @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?             @map("revoked_reason") @db.VarChar(120)
  replacedById  String?             @unique @map("replaced_by_id")
  userAgent     String?             @map("user_agent") @db.VarChar(255)
  ip            String?             @db.VarChar(45)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser     AdminUser?          @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  session       UserSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token")
}

model UserSession {
  id            String            @id @default(cuid())
  userId        String?           @map("user_id")
  adminUserId   String?           @map("admin_user_id")
  status        UserSessionStatus @default(ACTIVE)
  ip            String            @db.VarChar(45)
  userAgent     String            @map("user_agent") @db.VarChar(255)
  deviceLabel   String?           @map("device_label") @db.VarChar(80)
  geoCountry    String?           @map("geo_country") @db.VarChar(2)
  geoCity       String?           @map("geo_city") @db.VarChar(80)
  issuedAt      DateTime          @default(now()) @map("issued_at") @db.Timestamptz(6)
  lastSeenAt    DateTime          @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt     DateTime          @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?         @map("revoked_at") @db.Timestamptz(6)

  user          User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser     AdminUser?        @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([adminUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("user_session")
}

// =============================================================================
//  CATALOG ENUMS
// =============================================================================

enum CategoryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum ProductVariantStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
  COLOR_HEX
  LIST
}

enum MediaPurpose {
  PRODUCT_IMAGE
  PRODUCT_GALLERY
  CATEGORY_BANNER
  BRAND_LOGO
  REVIEW_ATTACHMENT
  AVATAR
  STATIC_PAGE
  SUPPORT_ATTACHMENT
  EMAIL_ASSET
}

// =============================================================================
//  CATALOG MODELS
// =============================================================================

model Category {
  id           String         @id @default(cuid())
  parentId     String?        @map("parent_id")
  slug         String         @unique @db.VarChar(120)
  name         String         @db.VarChar(160)
  description  String?        @db.Text
  imageMediaId String?        @map("image_media_id")
  displayOrder Int            @default(0) @map("display_order")
  level        Int            @default(0)
  path         String         @default("/") @db.VarChar(500)
  status       CategoryStatus @default(DRAFT)
  isFeatured   Boolean        @default(false) @map("is_featured")
  taxExempt    Boolean        @default(false) @map("tax_exempt")
  metaTitle    String?        @map("meta_title") @db.VarChar(255)
  metaDesc     String?        @map("meta_description") @db.VarChar(500)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  parent     Category?       @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children   Category[]      @relation("CategoryTree")
  products   Product[]

  @@index([parentId])
  @@index([slug])
  @@index([status, displayOrder])
  @@index([deletedAt])
  @@map("category")
}

model Brand {
  id           String      @id @default(cuid())
  slug         String      @unique @db.VarChar(120)
  name         String      @db.VarChar(160)
  description  String?     @db.Text
  logoMediaId  String?     @map("logo_media_id")
  isFeatured   Boolean     @default(false) @map("is_featured")
  status       BrandStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  products   Product[]

  @@index([status])
  @@index([slug])
  @@map("brand")
}

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique @db.VarChar(160)
  name          String        @db.VarChar(255)
  shortDesc     String?       @map("short_description") @db.VarChar(500)
  description   String?       @db.Text
  categoryId    String        @map("category_id")
  brandId       String?       @map("brand_id")
  basePrice     Decimal       @map("base_price") @db.Decimal(20, 4)
  compareAtPrice Decimal?     @map("compare_at_price") @db.Decimal(20, 4)
  status        ProductStatus @default(DRAFT)
  isFeatured    Boolean       @default(false) @map("is_featured")
  isNewArrival  Boolean       @default(false) @map("is_new_arrival")
  publishedAt   DateTime?     @map("published_at") @db.Timestamptz(6)
  viewCount     BigInt        @default(0) @map("view_count")
  ratingAvg     Decimal       @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount   Int           @default(0) @map("rating_count")
  tags          String[]      @default([])
  metaTitle     String?       @map("meta_title") @db.VarChar(255)
  metaDesc     String?       @map("meta_description") @db.VarChar(500)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand       Brand?                @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  images      ProductImage[]
  attributes  ProductAttributeValue[]

  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([brandId, status])
  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, status])
  @@index([deletedAt])
  @@map("product")
}

model ProductVariant {
  id             String               @id @default(cuid())
  productId      String               @map("product_id")
  sku            String               @unique @db.VarChar(64)
  barcode        String?              @db.VarChar(64)
  name           String               @db.VarChar(255)
  price          Decimal              @db.Decimal(20, 4)
  compareAtPrice Decimal?             @map("compare_at_price") @db.Decimal(20, 4)
  cost           Decimal?             @db.Decimal(20, 4)
  weightGrams    Int?                 @map("weight_grams")
  lengthMm       Int?                 @map("length_mm")
  widthMm        Int?                 @map("width_mm")
  heightMm       Int?                 @map("height_mm")
  status         ProductVariantStatus @default(ACTIVE)
  isDefault      Boolean              @default(false) @map("is_default")
  displayOrder   Int                  @default(0) @map("display_order")
  attributesJson Json                 @default("{}") @map("attributes_json") @db.JsonB
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?            @map("deleted_at") @db.Timestamptz(6)

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory?
  images    ProductImage[]
  cartItems CartItem[]

  @@index([productId, status, displayOrder])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
  @@map("product_variant")
}

model ProductImage {
  id             String          @id @default(cuid())
  productId      String          @map("product_id")
  variantId      String?         @map("variant_id")
  mediaId        String          @map("media_id")
  altText        String?         @map("alt_text") @db.VarChar(255)
  displayOrder   Int             @default(0) @map("display_order")
  isPrimary      Boolean         @default(false) @map("is_primary")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  media   MediaFile      @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([productId, displayOrder])
  @@index([variantId])
  @@map("product_image")
}

model ProductAttribute {
  id           String           @id @default(cuid())
  code         String           @unique @db.VarChar(60)
  displayName String           @map("display_name") @db.VarChar(120)
  dataType    AttributeDataType @default(TEXT) @map("data_type")
  unit        String?           @db.VarChar(20)
  isFilterable Boolean          @default(true) @map("is_filterable")
  isRequired   Boolean           @default(false) @map("is_required")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)

  values ProductAttributeValue[]

  @@map("product_attribute")
}

model ProductAttributeValue {
  id             String           @id @default(cuid())
  productId      String           @map("product_id")
  attributeId    String           @map("attribute_id")
  valueText      String?          @map("value_text") @db.VarChar(255)
  valueNumber    Decimal?         @map("value_number") @db.Decimal(20, 4)
  valueBoolean   Boolean?         @map("value_boolean")
  valueColorHex  String?          @map("value_color_hex") @db.VarChar(7)
  valueListValue String?         @map("value_list_value") @db.VarChar(120)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute   @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_value")
}

model MediaFile {
  id               String        @id @default(cuid())
  provider         String        @default("cloudinary") @db.VarChar(40)
  providerAssetId  String        @map("provider_asset_id") @db.VarChar(255)
  url              String        @db.Text
  secureUrl        String        @map("secure_url") @db.Text
  mimeType         String        @map("mime_type") @db.VarChar(60)
  sizeBytes        BigInt        @map("size_bytes")
  width            Int?
  height           Int?
  durationSeconds  Int?          @map("duration_seconds")
  purpose          MediaPurpose?
  variantsJson     Json          @default("{}") @map("variants_json") @db.JsonB
  checksum         String?       @db.VarChar(128)
  ownerType        String?       @map("owner_type") @db.VarChar(40)
  ownerId          String?       @map("owner_id")
  createdById      String?       @map("created_by_id")
  uploadedAt       DateTime      @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz(6)

  productImages ProductImage[]

  @@index([provider, providerAssetId])
  @@index([ownerType, ownerId])
  @@index([purpose, deletedAt])
  @@map("media_file")
}

model Inventory {
  id                 String   @id @default(cuid())
  productVariantId  String   @unique @map("product_variant_id")
  warehouseCode      String   @default("MAIN") @map("warehouse_code") @db.VarChar(40)
  onHand             Int      @default(0) @map("on_hand")
  reserved           Int      @default(0)
  available          Int      @default(0) @map("available")
  lowStockThreshold  Int      @default(5) @map("low_stock_threshold")
  allowBackorder     Boolean  @default(false) @map("allow_backorder")
  lastCountedAt      DateTime? @map("last_counted_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, warehouseCode])
  @@index([available])
  @@index([lowStockThreshold])
  @@map("inventory")
}

model AuditLog {
  id           String              @id @default(cuid())
  category     AuditActionCategory
  action       String              @db.VarChar(120)
  entityType   String              @map("entity_type") @db.VarChar(60)
  entityId     String              @map("entity_id") @db.VarChar(64)
  actorType    ActorType           @map("actor_type")
  actorUserId  String?             @map("actor_user_id")
  actorAdminId String?             @map("actor_admin_id")
  requestId    String?             @map("request_id") @db.VarChar(64)
  ipAddress    String?             @map("ip_address") @db.VarChar(45)
  userAgent    String?             @map("user_agent") @db.VarChar(255)
  beforeJson   Json?               @map("before_json") @db.JsonB
  afterJson    Json?               @map("after_json") @db.JsonB
  metadataJson Json                @default("{}") @map("metadata_json") @db.JsonB
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  actorAdmin AdminUser? @relation("AuditActorAdmin", fields: [actorAdminId], references: [id], onDelete: SetNull)

  @@index([category, createdAt(sort: Desc)])
  @@index([actorAdminId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_log")
}

// =============================================================================
//  CART & COUPON (cart-phase bounded context)
// =============================================================================

enum CartStatus {
  ACTIVE
  ABANDONED
  CHECKED_OUT
  EXPIRED
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id              String            @id @default(cuid())
  code            String            @unique @db.VarChar(40)
  description     String?           @db.Text
  discountType    CouponDiscountType @map("discount_type")
  discountValue   Decimal           @map("discount_value") @db.Decimal(12, 4)
  minCartTotal    Decimal           @default(0) @map("min_cart_total") @db.Decimal(20, 4)
  usageLimit      Int?              @map("usage_limit")
  usageCount      Int               @default(0) @map("usage_count")
  perUserLimit    Int?              @map("per_user_limit")
  validFrom       DateTime?         @map("valid_from") @db.Timestamptz(6)
  validUntil      DateTime?         @map("valid_until") @db.Timestamptz(6)
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  carts           Cart[]

  @@map("coupon")
}

model Cart {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  status             CartStatus  @default(ACTIVE)
  couponId           String?     @map("coupon_id")
  couponCode         String?     @map("coupon_code") @db.VarChar(40)
  currency           String      @default("VND") @db.VarChar(3)
  subtotal           Decimal     @default(0) @db.Decimal(20, 4)
  discountTotal      Decimal     @default(0) @map("discount_total") @db.Decimal(20, 4)
  taxTotal           Decimal     @default(0) @map("tax_total") @db.Decimal(20, 4)
  shippingTotal      Decimal     @default(0) @map("shipping_total") @db.Decimal(20, 4)
  estimatedShipping  Decimal     @default(0) @map("estimated_shipping") @db.Decimal(20, 4)
  grandTotal         Decimal     @default(0) @map("grand_total") @db.Decimal(20, 4)
  itemCount          Int         @default(0) @map("item_count")
  selectedItemCount  Int         @default(0) @map("selected_item_count")
  isItemSelected     Boolean     @default(false) @map("is_item_selected")
  notes              String?     @db.VarChar(500)
  promotionSnapshot  Json        @default("{}") @map("promotion_snapshot") @db.JsonB
  expiresAt          DateTime?   @map("expires_at") @db.Timestamptz(6)
  lastActivityAt     DateTime    @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz(6)

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon             Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              CartItem[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([lastActivityAt])
  @@map("cart")
}

model CartItem {
  id                    String        @id @default(cuid())
  cartId                String        @map("cart_id")
  productVariantId      String        @map("product_variant_id")
  quantity              Int
  unitPrice             Decimal       @map("unit_price") @db.Decimal(20, 4)
  discountSnapshot      Decimal       @default(0) @map("discount_snapshot") @db.Decimal(20, 4)
  subtotal              Decimal       @db.Decimal(20, 4)
  productNameSnapshot   String        @map("product_name_snapshot") @db.VarChar(255)
  variantNameSnapshot   String        @map("variant_name_snapshot") @db.VarChar(255)
  skuSnapshot           String        @map("sku_snapshot") @db.VarChar(64)
  productSlug           String        @map("product_slug") @db.VarChar(160)
  productImageUrl       String?       @map("product_image_url") @db.VarChar(500)
  color                 String?       @db.VarChar(60)
  size                  String?       @db.VarChar(60)
  isSelected            Boolean       @default(true) @map("is_selected")
  availableStockAtAdd   Int?          @map("available_stock_at_add")
  notes                 String?       @db.VarChar(500)
  promotionSnapshot     Json          @default("{}") @map("promotion_snapshot") @db.JsonB
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?     @map("deleted_at") @db.Timestamptz(6)

  cart                  Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant               ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([cartId, productVariantId])
  @@index([productVariantId])
  @@index([deletedAt])
  @@map("cart_item")
}

