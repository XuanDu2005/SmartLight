{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@smartlight/shared": ["../../packages/shared/src/index.ts"],
      "@smartlight/shared/*": ["../../packages/shared/src/*"],
      "@smartlight/config": ["../../packages/config/src/index.ts"],
      "@smartlight/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
