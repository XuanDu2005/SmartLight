# ============================================================================
# SmartLight — Customer Web (apps/web) environment template
#
# Only variables prefixed `VITE_` are exposed to the client at build time.
# Anything not prefixed is not accessible from the SPA bundle.
# ============================================================================

# Backend API base URL — bundled at build time.
# In production this is the public API URL (smartlight.vn → nginx → api:4000).
VITE_API_BASE_URL=https://smartlight.vn

# Public branding
VITE_APP_NAME=SmartLight
VITE_DEFAULT_LOCALE=vi-VN

# Sentry DSN (optional, used for browser-side error reporting)
VITE_SENTRY_DSN=

# Public analytics / marketing IDs (GTag, Meta Pixel, etc.)
VITE_GTAG_ID=
VITE_META_PIXEL_ID=

# Feature flags — bundled at build time, requires redeploy to change.
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_CHAT=false