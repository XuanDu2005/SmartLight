# ============================================================================
# SmartLight — Admin (apps/admin) environment template
#
# Only variables prefixed `VITE_` are exposed to the admin SPA at build time.
# ============================================================================

# Backend API base URL (admin uses the same API but a different role/cookie).
VITE_ADMIN_API_BASE_URL=https://smartlight.vn

# Public branding
VITE_ADMIN_APP_NAME=SmartLight Admin
VITE_DEFAULT_LOCALE=vi-VN

# Sentry DSN (admin gets its own project for cleaner alerting).
VITE_SENTRY_DSN=

# Feature flags
VITE_ENABLE_AUDIT_LOG=false
VITE_ENABLE_TWO_FACTOR=true